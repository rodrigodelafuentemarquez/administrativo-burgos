---
interface Props { mode?: 'normal' | 'fails'; }
const { mode = 'normal' } = Astro.props;
---

<section class="card">
  <div id="test-app" data-mode={mode}></div>
</section>

<script type="module">
  import { addFails, readFails, removeFailIds, updateStats } from '../utils/storage';

  const root = document.getElementById('test-app');
  const mode = root?.dataset.mode ?? 'normal';
  const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

  const limitOptions = [5, 10, 20, 30, 0];
  let allQuestions = [];
  let selected = [];

  async function loadNormalQuestions() {
    const idxRes = await fetch(`${base}data/tests/index.json`);
    const idx = await idxRes.json();
    const temas = (idx.temas ?? []).filter((t) => (t.preguntas ?? 0) > 0);
    if (!temas.length) {
      root.innerHTML = '<p>No hay preguntas cargadas todavía. Puedes añadir JSON de tests más adelante.</p>';
      return;
    }

    root.innerHTML = `
      <h2>Configurar test</h2>
      <div style="display:grid;gap:.8rem">
        <fieldset><legend>Temas</legend>${temas.map((t) => `<label style='display:block'><input type='checkbox' value='${t.tema}' checked> Tema ${t.tema}</label>`).join('')}</fieldset>
        <label>Número de preguntas
          <select id='limit'>${limitOptions.map((n) => `<option value='${n}'>${n === 0 ? 'Todas' : n}</option>`).join('')}</select>
        </label>
        <button class='primary' id='start'>Empezar</button>
      </div>`;

    document.getElementById('start')?.addEventListener('click', async () => {
      const temaIds = Array.from(root.querySelectorAll('input[type=checkbox]:checked')).map((el) => Number(el.value));
      const chunks = await Promise.all(temaIds.map(async (id) => {
        const r = await fetch(`${base}data/tests/tema-${String(id).padStart(2, '0')}.json`);
        return r.json();
      }));
      allQuestions = chunks.flat();
      startTest(Number(document.getElementById('limit')?.value ?? '10'));
    });
  }

  function shuffle(arr) {
    return arr.map((v) => [Math.random(), v]).sort((a,b) => a[0]-b[0]).map((x) => x[1]);
  }

  function startTest(limit) {
    if (mode === 'fails') {
      allQuestions = readFails();
      if (!allQuestions.length) {
        root.innerHTML = '<p>No hay fallos guardados.</p>';
        return;
      }
    }
    selected = shuffle(allQuestions);
    if (limit > 0) selected = selected.slice(0, limit);

    const answers = new Map();
    root.innerHTML = `<h2>Test</h2><form id='quiz'></form><button class='primary' id='finish'>Corregir</button>`;
    const quiz = document.getElementById('quiz');
    selected.forEach((q, i) => {
      const div = document.createElement('article');
      div.className = 'card';
      div.style.margin = '.8rem 0';
      div.innerHTML = `<p><strong>${i+1}. ${q.pregunta}</strong></p>${q.opciones.map((op, j) => `<label style='display:block;margin:.2rem 0'><input type='radio' name='q${i}' value='${j}'> ${op}</label>`).join('')}`;
      quiz.appendChild(div);
    });

    document.getElementById('finish')?.addEventListener('click', (e) => {
      e.preventDefault();
      let ok = 0;
      const failed = [];
      selected.forEach((q, i) => {
        const pick = Number((document.querySelector(`input[name=q${i}]:checked`) || {}).value ?? -1);
        answers.set(q.id, pick);
        if (pick === q.correcta) ok += 1; else failed.push(q);
      });

      if (mode === 'fails') {
        const successIds = selected.filter((q) => answers.get(q.id) === q.correcta).map((q) => q.id);
        removeFailIds(successIds);
      } else {
        const byTema = new Map();
        selected.forEach((q) => {
          const prev = byTema.get(q.tema) ?? { total: 0, ok: 0 };
          prev.total += 1;
          if (answers.get(q.id) === q.correcta) prev.ok += 1;
          byTema.set(q.tema, prev);
        });
        byTema.forEach((v, tema) => updateStats(tema, v.total, v.ok));
        addFails(failed);
      }

      root.innerHTML = `<h2>Resultado: ${ok}/${selected.length}</h2>${selected.map((q, i) => {
        const pick = answers.get(q.id);
        const correct = pick === q.correcta;
        return `<article class='card' style='margin:.8rem 0;border-color:${correct ? '#16a34a' : '#dc2626'}'>
          <p><strong>${i+1}. ${q.pregunta}</strong></p>
          <p>Tu respuesta: ${pick >= 0 ? q.opciones[pick] : 'Sin responder'}</p>
          <p>Correcta: ${q.opciones[q.correcta]}</p>
          <p class='muted'>Explicación: ${q.explicacion}</p>
          <p class='muted'>Referencia: ${q.referencia}</p>
        </article>`;
      }).join('')}<button id='again' class='primary'>Nuevo test</button>`;
      document.getElementById('again')?.addEventListener('click', () => mode === 'fails' ? startTest(0) : loadNormalQuestions());
    });
  }

  if (mode === 'fails') {
    root.innerHTML = `<h2>Repetir fallos</h2><label>Número de preguntas
      <select id='limit'>${limitOptions.map((n) => `<option value='${n}'>${n === 0 ? 'Todas' : n}</option>`).join('')}</select></label>
      <button id='start' class='primary'>Empezar</button>`;
    document.getElementById('start')?.addEventListener('click', () => startTest(Number(document.getElementById('limit')?.value ?? '0')));
  } else {
    loadNormalQuestions();
  }
</script>
