---
interface Props { mode?: 'normal' | 'fails' | 'doubts'; }
const { mode = 'normal' } = Astro.props;
const clientBase = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<section class="test-shell card border-0 shadow-sm">
  <div id="test-app" data-mode={mode} data-base={clientBase}></div>
</section>

<script>
  import {
    updateStats,
    readFails,
    addFails,
    removeFailIds,
    readDoubts,
    toggleDoubt,
    removeDoubtIds,
  } from '../utils/storage';

  const root = document.getElementById('test-app');
  const mode = root?.dataset.mode ?? 'normal';
  const base = root?.dataset.base ?? '/';

  const practiceLimitOptions = [10, 20, 30, 50, 70, 100];
  const officialLimitOptions = [70, 100];
  const failLimitOptions = [0, ...practiceLimitOptions];
  const timerOptions = [0, 60, 75, 90, 120];
  const penaltyOptions = [
    { value: 0, label: 'Sin penalización' },
    { value: 0.25, label: 'Penalización -0,25 por fallo' },
    { value: 0.33, label: 'Penalización -0,33 por fallo' },
  ];

  let allQuestions = [];
  let selected = [];
  let currentSessionMode = 'practice';
  let currentFailFilter = 'mixed';
  let currentDoubtFilter = 'mixed';
  let currentPenalty = 0;
  let currentTimerMinutes = 0;
  let activeTimerId = null;
  let sessionFinished = false;
  let finishReason = 'manual';

  function normalizeQuestion(item, fallbackTema, index) {
    if (Array.isArray(item)) {
      const [pregunta = '', opciones = [], correcta = 0, _explicacion = '', referencia = ''] = item;
      item = {
        id: `t${String(fallbackTema).padStart(2, '0')}-p${String(index + 1).padStart(3, '0')}`,
        tema: fallbackTema,
        pregunta,
        opciones,
        correcta,
        referencia,
      };
    }

    if (!item || typeof item !== 'object') return null;

    const opciones = Array.isArray(item.opciones) ? item.opciones.map((value) => String(value ?? '')) : [];
    const correcta = Number(item.correcta);
    const tema = Number(item.tema ?? fallbackTema);
    if (opciones.length !== 4 || ![0, 1, 2, 3].includes(correcta)) return null;

    return {
      ...item,
      id: String(item.id ?? `t${String(tema).padStart(2, '0')}-p${String(index + 1).padStart(3, '0')}`),
      tema,
      pregunta: String(item.pregunta ?? ''),
      opciones,
      correcta,
      referencia: String(item.referencia ?? ''),
      tags: Array.isArray(item.tags) ? item.tags.map((tag) => String(tag ?? '')).filter(Boolean) : [],
      fallos: Math.max(1, Number(item.fallos ?? 1) || 1),
      firstFailedAt: Number(item.firstFailedAt ?? 0) || null,
      lastFailedAt: Number(item.lastFailedAt ?? 0) || null,
      createdAt: Number(item.createdAt ?? 0) || null,
    };
  }

  const escapeHtml = (value) => String(value ?? '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');

  function renderQuestionTags(question) {
    const tags = Array.isArray(question.tags) ? question.tags.filter(Boolean) : [];
    if (!tags.length) return '';
    return `<span class="question-tags">${tags.map((tag) => `<span class="badge text-bg-success">${escapeHtml(tag)}</span>`).join('')}</span>`;
  }

  function shuffle(arr) {
    return arr.map((v) => [Math.random(), v]).sort((a, b) => a[0] - b[0]).map((x) => x[1]);
  }

  function optionOrderMatters(question) {
    const texts = [question.pregunta, ...(question.opciones ?? [])]
      .map((value) => String(value ?? '').toLowerCase());
    const joined = texts.join(' || ');
    return [
      /\blas respuestas?\s+[abcd](?:\)|\.)?\s+y\s+[abcd](?:\)|\.)?/,
      /\brespuesta\s+[abcd](?:\)|\.)?/,
      /\b[abcd]\s+y\s+[abcd]\s+son\s+correctas\b/,
      /\bopciones?\s+[abcd](?:\)|\.)?\s+y\s+[abcd](?:\)|\.)?/,
      /\banteriores?\b/,
      /\bsiguientes?\b/,
    ].some((pattern) => pattern.test(joined));
  }

  function shuffleQuestionOptions(question) {
    if (optionOrderMatters(question)) {
      return { ...question, opciones: [...question.opciones] };
    }

    const options = question.opciones.map((texto, index) => ({
      texto,
      originalIndex: index,
      sortKey: Math.random(),
    }));
    options.sort((a, b) => a.sortKey - b.sortKey);

    return {
      ...question,
      opciones: options.map((entry) => entry.texto),
      correcta: options.findIndex((entry) => entry.originalIndex === question.correcta),
    };
  }

  function clearActiveTimer() {
    if (activeTimerId) {
      window.clearInterval(activeTimerId);
      activeTimerId = null;
    }
  }

  function formatDuration(totalSeconds) {
    const safe = Math.max(0, Number(totalSeconds) || 0);
    const minutes = Math.floor(safe / 60);
    const seconds = safe % 60;
    return `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
  }

  function formatPenalty(value) {
    return String(Number(value || 0).toFixed(2)).replace('.', ',');
  }

  function getLimitChoices(sessionMode) {
    return sessionMode === 'official' ? officialLimitOptions : practiceLimitOptions;
  }

  function getCoverageTone(count) {
    if (count >= 40) return 'success';
    if (count >= 30) return 'primary';
    if (count >= 20) return 'warning';
    return 'danger';
  }

  function sortByRecurringDifficulty(items) {
    return [...items].sort((a, b) => {
      if ((b.fallos ?? 1) !== (a.fallos ?? 1)) return (b.fallos ?? 1) - (a.fallos ?? 1);
      return (b.lastFailedAt ?? 0) - (a.lastFailedAt ?? 0);
    });
  }

  function buildSmartSelection(limit) {
    const desired = limit > 0 ? Math.min(limit, allQuestions.length) : allQuestions.length;
    if (!desired) return [];

    const availableById = new Map(allQuestions.map((item) => [item.id, item]));
    const normalizedFails = readFails()
      .map((item, index) => normalizeQuestion(item, Number(item?.tema ?? 0), index))
      .filter(Boolean)
      .filter((item) => availableById.has(item.id));

    const recurrent = sortByRecurringDifficulty(
      normalizedFails
        .filter((item) => Number(item.fallos ?? 1) >= 2)
        .map((item) => ({ ...availableById.get(item.id), fallos: item.fallos, firstFailedAt: item.firstFailedAt, lastFailedAt: item.lastFailedAt }))
    );

    const failedIdSet = new Set(normalizedFails.map((item) => item.id));
    const pickedIds = new Set();
    const recurrentTarget = Math.min(
      recurrent.length,
      desired >= 20 ? Math.max(8, Math.round(desired * 0.5)) : Math.max(4, Math.round(desired * 0.45)),
    );

    const recurrentPicked = recurrent.slice(0, recurrentTarget);
    recurrentPicked.forEach((item) => pickedIds.add(item.id));

    const freshPool = shuffle(allQuestions.filter((item) => !failedIdSet.has(item.id) && !pickedIds.has(item.id)));
    const seenPool = shuffle(allQuestions.filter((item) => failedIdSet.has(item.id) && !pickedIds.has(item.id)));
    const reservePool = shuffle(allQuestions.filter((item) => !pickedIds.has(item.id)));

    const ordered = [];
    const recurrentQueue = [...recurrentPicked];
    const freshQueue = [...freshPool];

    while (ordered.length < desired && (recurrentQueue.length || freshQueue.length)) {
      if (recurrentQueue.length) ordered.push(recurrentQueue.shift());
      if (ordered.length < desired && recurrentQueue.length) ordered.push(recurrentQueue.shift());
      if (ordered.length < desired && freshQueue.length) ordered.push(freshQueue.shift());
    }

    for (const pool of [seenPool, reservePool]) {
      while (ordered.length < desired && pool.length) {
        const next = pool.shift();
        if (!next || pickedIds.has(next.id)) continue;
        ordered.push(next);
        pickedIds.add(next.id);
      }
    }

    return ordered.slice(0, desired);
  }

  function syncLimitOptions(defaultValue) {
    const modeSelect = document.getElementById('session-mode');
    const limitSelect = document.getElementById('limit');
    if (!modeSelect || !limitSelect) return;

    const sessionMode = modeSelect.value ?? 'practice';
    const options = getLimitChoices(sessionMode);
    const preferred = Number(defaultValue ?? limitSelect.value ?? (sessionMode === 'official' ? 70 : 20));
    limitSelect.innerHTML = options
      .map((n) => `<option value="${n}">${n}</option>`)
      .join('');
    limitSelect.value = String(options.includes(preferred) ? preferred : (sessionMode === 'official' ? 70 : 20));
  }

  function applyModePreset(sessionMode) {
    const limitSelect = document.getElementById('limit');
    const timerSelect = document.getElementById('timer-minutes');
    const penaltySelect = document.getElementById('penalty-mode');
    if (!limitSelect || !timerSelect || !penaltySelect) return;

    if (sessionMode === 'official') {
      syncLimitOptions(70);
      limitSelect.value = '70';
      timerSelect.value = '90';
      penaltySelect.value = '0.25';
      return;
    }

    if (sessionMode === 'smart') {
      syncLimitOptions(30);
      if (timerSelect.value === '90') timerSelect.value = '0';
      return;
    }

    syncLimitOptions(20);
  }

  function startTimer(totalMinutes) {
    clearActiveTimer();
    if (!(totalMinutes > 0)) return;

    const timerNode = document.getElementById('timer-display');
    if (!timerNode) return;

    const startedAt = Date.now();
    const totalSeconds = Math.round(totalMinutes * 60);

    const tick = () => {
      const elapsedSeconds = Math.floor((Date.now() - startedAt) / 1000);
      const remainingSeconds = Math.max(0, totalSeconds - elapsedSeconds);
      timerNode.textContent = formatDuration(remainingSeconds);
      timerNode.dataset.state = remainingSeconds <= 60 ? 'ending' : 'running';
      if (remainingSeconds <= 0) {
        clearActiveTimer();
        finishReason = 'timeout';
        finishTest(new Event('submit'));
      }
    };

    tick();
    activeTimerId = window.setInterval(tick, 1000);
  }

  function renderEmpty(message, help = '') {
    root.innerHTML = `
      <div class="test-empty text-center py-4">
        <span class="test-kicker">Tests</span>
        <h2 class="h3 mt-2">${escapeHtml(message)}</h2>
        ${help ? `<p class="text-body-secondary mb-0">${escapeHtml(help)}</p>` : ''}
      </div>`;
  }

  function updateTopicSelectionSummary() {
    const checked = Array.from(root.querySelectorAll('.test-topic-option input[type=checkbox]:checked'));
    const topicCount = checked.length;
    const questionCount = checked.reduce((sum, input) => sum + Number(input.dataset.preguntas ?? '0'), 0);
    const summary = document.getElementById('topic-selection-summary');
    if (!summary) return;
    summary.innerHTML = `
      <span class="badge text-bg-secondary">${topicCount} tema(s) seleccionados</span>
      <span class="badge text-bg-primary">${questionCount} preguntas disponibles</span>
    `;
  }

  function getFailBuckets(fails) {
    const recurrentes = fails.filter((q) => Number(q.fallos ?? 1) >= 2);
    const nuevos = fails.filter((q) => Number(q.fallos ?? 1) < 2);
    return { nuevos, recurrentes };
  }

  function getFailPool(filter) {
    const normalizedFails = readFails()
      .map((item, index) => normalizeQuestion(item, Number(item?.tema ?? 0), index))
      .filter(Boolean);

    const { nuevos, recurrentes } = getFailBuckets(normalizedFails);
    if (filter === 'new') {
      return [...nuevos].sort((a, b) => (b.lastFailedAt ?? 0) - (a.lastFailedAt ?? 0));
    }
    if (filter === 'recurrent') {
      return sortByRecurringDifficulty(recurrentes);
    }

    return [
      ...sortByRecurringDifficulty(recurrentes),
      ...[...nuevos].sort((a, b) => (b.lastFailedAt ?? 0) - (a.lastFailedAt ?? 0)),
    ];
  }

  function getDoubtBuckets(doubts) {
    const recurrentIds = new Set(readFails().filter((item) => Number(item.fallos ?? 1) >= 2).map((item) => item.id));
    const recurrentes = doubts.filter((q) => recurrentIds.has(q.id));
    const nuevas = doubts.filter((q) => !recurrentIds.has(q.id));
    return { nuevas, recurrentes };
  }

  function getDoubtPool(filter) {
    const doubts = readDoubts()
      .map((item, index) => normalizeQuestion(item, Number(item?.tema ?? 0), index))
      .filter(Boolean);
    const { nuevas, recurrentes } = getDoubtBuckets(doubts);
    if (filter === 'recurrent') return sortByRecurringDifficulty(recurrentes);
    if (filter === 'new') return [...nuevas].sort((a, b) => (b.createdAt ?? 0) - (a.createdAt ?? 0));
    return [
      ...sortByRecurringDifficulty(recurrentes),
      ...[...nuevas].sort((a, b) => (b.createdAt ?? 0) - (a.createdAt ?? 0)),
    ];
  }

  async function loadNormalQuestions() {
    const idxRes = await fetch(`${base}data/tests/index.json`);
    const idx = await idxRes.json();
    const idxList = Array.isArray(idx) ? idx : (Array.isArray(idx?.temas) ? idx.temas : []);
    const temas = idxList
      .map((t) => ({
        ...t,
        tema: Number(t?.tema ?? 0),
        preguntas: Number(t?.preguntas ?? 0),
        titulo: String(t?.titulo ?? '').trim(),
      }))
      .filter((t) => t.tema > 0 && t.preguntas > 0);
    if (!temas.length) {
      renderEmpty('No hay preguntas cargadas todavía.', 'Cuando añadamos los JSON por tema aparecerán aquí automáticamente.');
      return;
    }

    const strong = temas.filter((t) => t.preguntas >= 40).length;
    const solid = temas.filter((t) => t.preguntas >= 30 && t.preguntas < 40).length;
    const minimum = temas.filter((t) => t.preguntas >= 20 && t.preguntas < 30).length;

    root.innerHTML = `
      <div class="test-hero mb-4">
        <span class="test-kicker">Modo test</span>
        <h2 class="display-6 mb-2">Configurar test</h2>
        <p class="text-body-secondary mb-0">Elige temas, tamaño y formato. Puedes alternar práctica, simulacro oficial o repaso inteligente con penalización y temporizador opcionales.</p>
      </div>
      <div class="test-config">
        <fieldset class="test-panel">
          <legend class="h5 mb-3">Temas disponibles</legend>
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-outline-secondary btn-sm" id="select-all-topics" type="button">Test general</button>
              <button class="btn btn-outline-secondary btn-sm" id="clear-topics" type="button">Quitar selección</button>
            </div>
          </div>
          <p class="text-body-secondary small mb-2">Puedes mezclar varios temas en un mismo test. "Test general" marca todos los temas disponibles.</p>
          <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge text-bg-success">Fuertes: ${strong}</span>
            <span class="badge text-bg-primary">Solidos: ${solid}</span>
            <span class="badge text-bg-warning text-dark">En minimo: ${minimum}</span>
          </div>
          <div class="d-flex flex-wrap gap-2 mb-3" id="topic-selection-summary"></div>
          <div class="test-topic-grid">
            ${temas.map((t) => `
              <label class="test-topic-option">
                <input class="form-check-input" type="checkbox" value="${Number(t.tema)}" data-preguntas="${Number(t.preguntas)}" checked>
                <span>
                  <span class="test-topic-heading">
                    <strong>Tema ${Number(t.tema)}</strong>
                    <span class="test-topic-count badge text-bg-${getCoverageTone(Number(t.preguntas))}">${Number(t.preguntas)} preguntas</span>
                  </span>
                  ${t.titulo ? `<small>${escapeHtml(t.titulo)}</small>` : ''}
                </span>
              </label>`).join('')}
          </div>
        </fieldset>
        <div class="test-panel">
          <label class="form-label fw-semibold" for="session-mode">Formato</label>
          <select class="form-select mb-3" id="session-mode">
            <option value="practice" selected>Práctica guiada</option>
            <option value="official">Simulacro oficial</option>
            <option value="smart">Repaso inteligente</option>
          </select>
          <p class="text-body-secondary small mb-3">Práctica muestra la referencia durante el examen. Simulacro oficial se ajusta por defecto a 70 preguntas, 90 minutos y penalización de 0,25. Repaso inteligente carga antes lo que más se te atraganta.</p>
          <label class="form-label fw-semibold" for="limit">Número de preguntas</label>
          <select class="form-select mb-3" id="limit"></select>
          <label class="form-label fw-semibold" for="timer-minutes">Temporizador orientativo</label>
          <select class="form-select mb-3" id="timer-minutes">${timerOptions.map((n) => `<option value="${n}" ${n === 0 ? 'selected' : ''}>${n === 0 ? 'Sin temporizador' : `${n} minutos`}</option>`).join('')}</select>
          <label class="form-label fw-semibold" for="penalty-mode">Corrección</label>
          <select class="form-select" id="penalty-mode">${penaltyOptions.map((option) => `<option value="${option.value}" ${option.value === 0 ? 'selected' : ''}>${option.label}</option>`).join('')}</select>
          <p class="text-body-secondary small mt-2 mb-0">La penalización solo afecta a la nota mostrada del intento. El progreso por tema sigue contando aciertos reales. Si no hay suficientes preguntas, se usan todas las disponibles.</p>
          <button class="btn btn-primary btn-lg w-100 mt-3" id="start" type="button">Empezar test</button>
        </div>
      </div>`;

    applyModePreset('practice');
    updateTopicSelectionSummary();

    document.getElementById('session-mode')?.addEventListener('change', () => {
      applyModePreset(document.getElementById('session-mode')?.value ?? 'practice');
    });

    document.getElementById('select-all-topics')?.addEventListener('click', () => {
      root.querySelectorAll('input[type=checkbox]').forEach((el) => {
        el.checked = true;
      });
      updateTopicSelectionSummary();
    });

    document.getElementById('clear-topics')?.addEventListener('click', () => {
      root.querySelectorAll('.test-topic-option input[type=checkbox]').forEach((el) => {
        el.checked = false;
      });
      updateTopicSelectionSummary();
    });

    root.querySelectorAll('.test-topic-option input[type=checkbox]').forEach((el) => {
      el.addEventListener('change', updateTopicSelectionSummary);
    });

    document.getElementById('start')?.addEventListener('click', async () => {
      const temaIds = Array.from(root.querySelectorAll('.test-topic-option input[type=checkbox]:checked')).map((el) => Number(el.value));
      currentSessionMode = document.getElementById('session-mode')?.value ?? 'practice';
      if (!temaIds.length) {
        renderEmpty('Selecciona al menos un tema.', 'Vuelve a Tests y marca un tema para empezar.');
        return;
      }
      const chunks = await Promise.all(temaIds.map(async (id) => {
        const r = await fetch(`${base}data/tests/tema-${String(id).padStart(2, '0')}.json`);
        const raw = await r.json();
        return (Array.isArray(raw) ? raw : [])
          .map((item, index) => normalizeQuestion(item, id, index))
          .filter(Boolean);
      }));
      allQuestions = chunks.flat();
      if (!allQuestions.length) {
        renderEmpty('No hay preguntas válidas en los temas seleccionados.', 'Revisa los JSON de test o prueba con otros temas.');
        return;
      }
      currentPenalty = Number(document.getElementById('penalty-mode')?.value ?? '0') || 0;
      currentTimerMinutes = Number(document.getElementById('timer-minutes')?.value ?? '0') || 0;
      startTest(Number(document.getElementById('limit')?.value ?? '10'), currentSessionMode);
    });
  }

  function startTest(limit, sessionMode = currentSessionMode) {
    currentSessionMode = sessionMode;
    sessionFinished = false;
    finishReason = 'manual';
    clearActiveTimer();

    if (mode === 'fails') {
      currentPenalty = 0;
      currentTimerMinutes = 0;
      allQuestions = getFailPool(currentFailFilter);
      if (!allQuestions.length) {
        renderEmpty('No hay fallos en ese bloque.', 'Prueba con otro filtro o vuelve a la práctica general para generar nuevas preguntas falladas.');
        return;
      }
      selected = allQuestions.slice(0, limit > 0 ? limit : allQuestions.length);
    } else if (mode === 'doubts') {
      currentPenalty = 0;
      currentTimerMinutes = 0;
      allQuestions = getDoubtPool(currentDoubtFilter);
      if (!allQuestions.length) {
        renderEmpty('No hay preguntas dudosas ahora mismo.', 'Marca preguntas desde la corrección del test y aparecerán aquí.');
        return;
      }
      selected = allQuestions.slice(0, limit > 0 ? limit : allQuestions.length);
    } else if (currentSessionMode === 'smart') {
      selected = buildSmartSelection(limit);
    } else {
      selected = shuffle(allQuestions);
      if (limit > 0) selected = selected.slice(0, limit);
    }

    selected = selected.map((question) => shuffleQuestionOptions(question));

    const isOfficial = currentSessionMode === 'official' && mode === 'normal';
    const isSmart = currentSessionMode === 'smart' && mode === 'normal';
    const heroLabel = mode === 'fails'
      ? 'Repaso de fallos'
      : (mode === 'doubts'
        ? 'Revision de dudosas'
        : (isOfficial ? 'Simulacro oficial' : (isSmart ? 'Repaso inteligente' : 'Test aleatorio')));

    const heroText = mode === 'fails'
      ? 'Las preguntas se priorizan por recurrencia de error. Si aciertas una aquí, desaparece de fallos.'
      : (mode === 'doubts'
        ? 'Este bloque agrupa preguntas que has marcado para revisar con calma. Si aquí ya las ves claras, se limpian automáticamente al acertarlas.'
        : (isOfficial
          ? 'Sin pistas durante el examen: la referencia normativa solo aparece al corregir. Ajuste inicial: 70 preguntas, 90 minutos y penalización de 0,25.'
          : (isSmart
            ? 'Combina preguntas nuevas con fallos recurrentes del bloque elegido para repasar sin repetir siempre lo mismo.'
            : 'Marca una opción por pregunta. La corrección aparece al final con la respuesta correcta y la referencia.')));

    const timerBadge = mode === 'normal' && currentTimerMinutes > 0
      ? `<span class="badge text-bg-dark" id="timer-display">${formatDuration(Math.round(currentTimerMinutes * 60))}</span>`
      : '';
    const penaltyBadge = mode === 'normal' && currentPenalty > 0
      ? `<span class="badge text-bg-secondary">Penalización -${formatPenalty(currentPenalty)} por fallo</span>`
      : '';
    const modeBadge = isSmart ? '<span class="badge text-bg-info">Nuevas + recurrentes</span>' : '';

    root.innerHTML = `
      <div class="test-hero mb-4">
        <span class="test-kicker">${heroLabel}</span>
        <h2 class="display-6 mb-2">${selected.length} preguntas</h2>
        <p class="text-body-secondary mb-0">${heroText}</p>
        ${(timerBadge || penaltyBadge || modeBadge) ? `<div class="d-flex flex-wrap gap-2 mt-3">${modeBadge}${penaltyBadge}${timerBadge}</div>` : ''}
      </div>
      <form id="quiz" class="test-question-list"></form>
      <div class="test-actions sticky-bottom py-3 mt-4">
        <button class="btn btn-primary btn-lg" id="finish" type="submit">Corregir test</button>
      </div>`;

    const quiz = document.getElementById('quiz');
    selected.forEach((q, i) => {
      const div = document.createElement('article');
      div.className = 'question-card card border-0 shadow-sm';
      div.innerHTML = `
        <div class="card-body p-4">
          <div class="d-flex align-items-start gap-3 mb-3">
            <span class="question-number">${i + 1}</span>
            <div>
              <p class="question-meta mb-1">${isOfficial ? `Tema ${Number(q.tema)}` : `Tema ${Number(q.tema)} · ${escapeHtml(q.referencia)}`} ${renderQuestionTags(q)}</p>
              <h3 class="h5 mb-0">${escapeHtml(q.pregunta)}</h3>
            </div>
          </div>
          <div class="answer-list">
            ${q.opciones.map((op, j) => `
              <label class="answer-option" for="q${i}-${j}">
                <input class="form-check-input" id="q${i}-${j}" type="radio" name="q${i}" value="${j}">
                <span>${escapeHtml(op)}</span>
              </label>`).join('')}
          </div>
        </div>`;
      quiz.appendChild(div);
    });

    document.getElementById('finish')?.addEventListener('click', finishTest);
    if (mode === 'normal' && currentTimerMinutes > 0) {
      startTimer(currentTimerMinutes);
    }
  }

  function finishTest(event) {
    event?.preventDefault?.();
    if (sessionFinished) return;
    sessionFinished = true;
    clearActiveTimer();
    const answers = new Map();
    let ok = 0;
    const failed = [];

    selected.forEach((q, i) => {
      const pick = Number((document.querySelector(`input[name=q${i}]:checked`) || {}).value ?? -1);
      answers.set(q.id, pick);
      if (pick === q.correcta) ok += 1;
      else failed.push(q);
    });

    if (mode === 'fails') {
      const successIds = selected.filter((q) => answers.get(q.id) === q.correcta).map((q) => q.id);
      removeFailIds(successIds);
    } else if (mode === 'doubts') {
      const successIds = selected.filter((q) => answers.get(q.id) === q.correcta).map((q) => q.id);
      removeDoubtIds(successIds);
    } else {
      const byTema = new Map();
      selected.forEach((q) => {
        const prev = byTema.get(q.tema) ?? { total: 0, ok: 0 };
        prev.total += 1;
        if (answers.get(q.id) === q.correcta) prev.ok += 1;
        byTema.set(q.tema, prev);
      });
      byTema.forEach((v, tema) => updateStats(tema, v.total, v.ok));
      addFails(failed);
    }

    const percent = selected.length ? Math.round((ok / selected.length) * 100) : 0;
    const wrong = failed.length;
    const netScore = Number((ok - (wrong * currentPenalty)).toFixed(2));
    const netPercent = selected.length ? Math.round((netScore / selected.length) * 100) : 0;
    const failMessage = mode === 'fails'
      ? (failed.length ? `${failed.length} pregunta(s) siguen en fallos.` : 'Has vaciado este bloque de fallos.')
      : (mode === 'doubts'
        ? (failed.length ? `${failed.length} pregunta(s) siguen marcadas o dudosas.` : 'Has limpiado todas las dudosas de este bloque.')
        : (failed.length ? `${failed.length} pregunta(s) guardada(s) en fallos.` : 'Sin fallos. Limpio como una patena.'));
    const timingMessage = finishReason === 'timeout'
      ? '<p class="text-warning-emphasis mb-0 mt-2">El temporizador ha llegado a cero y el test se ha corregido automáticamente.</p>'
      : '';
    const penaltyMessage = mode === 'normal' && currentPenalty > 0
      ? `<p class="text-body-secondary mb-0 mt-2">Nota neta con penalización de ${formatPenalty(currentPenalty)} por fallo: <strong>${String(netScore.toFixed(2)).replace('.', ',')}</strong> sobre ${selected.length} (${netPercent}%).</p>`
      : '';

    root.innerHTML = `
      <div class="result-summary card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
          <span class="test-kicker">Corrección</span>
          <div class="d-lg-flex align-items-center justify-content-between gap-4">
            <div>
              <h2 class="display-6 mb-2">${ok}/${selected.length} correctas</h2>
              <p class="text-body-secondary mb-lg-0">${failMessage}</p>
              ${penaltyMessage}
              ${timingMessage}
            </div>
            <div class="score-ring" style="--score:${percent}%">${percent}%</div>
          </div>
        </div>
      </div>
      <div class="test-question-list">
        ${selected.map((q, i) => renderCorrection(q, i, answers.get(q.id))).join('')}
      </div>
      ${mode === 'normal' ? '<div id="doubt-feedback" class="mt-3"></div>' : ''}
      <button id="again" class="btn btn-primary btn-lg mt-4" type="button">Nuevo test</button>`;

    window.scrollTo({
      top: Math.max(0, root.getBoundingClientRect().top + window.scrollY - 88),
      behavior: 'smooth',
    });

    document.getElementById('again')?.addEventListener('click', () => {
      if (mode === 'fails') return loadFailsView();
      if (mode === 'doubts') return loadDoubtsView();
      return loadNormalQuestions();
    });

    if (mode === 'normal') {
      root.querySelectorAll('.toggle-doubt').forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.dataset.id ?? '';
          const question = selected.find((item) => item.id === id);
          if (!question) return;
          const active = toggleDoubt({
            id: question.id,
            tema: question.tema,
            pregunta: question.pregunta,
            opciones: question.opciones,
            correcta: question.correcta,
            referencia: question.referencia,
            tags: question.tags,
          });
          button.textContent = active ? 'Quitar duda' : 'Marcar dudosa';
          button.className = active ? 'btn btn-sm btn-warning toggle-doubt' : 'btn btn-sm btn-outline-warning toggle-doubt';
          const feedback = document.getElementById('doubt-feedback');
          if (feedback) {
            feedback.innerHTML = `<div class="alert alert-${active ? 'warning' : 'secondary'} border-0 shadow-sm mb-0">${active ? 'Pregunta marcada como dudosa.' : 'Pregunta quitada de dudosas.'}</div>`;
          }
        });
      });
    }
  }

  function renderCorrection(q, i, pick) {
    const correct = pick === q.correcta;
    const failBadge = mode === 'fails' && Number(q.fallos ?? 1) >= 2
      ? `<span class="badge text-bg-warning ms-2">Recurrente · ${Number(q.fallos)} fallos</span>`
      : '';
    const hasDoubt = readDoubts().some((item) => item.id === q.id);
    const doubtButton = mode === 'normal'
      ? `<button type="button" class="${hasDoubt ? 'btn btn-sm btn-warning' : 'btn btn-sm btn-outline-warning'} toggle-doubt" data-id="${escapeHtml(q.id)}">${hasDoubt ? 'Quitar duda' : 'Marcar dudosa'}</button>`
      : '';

    return `
      <article class="correction-card card border-0 shadow-sm ${correct ? 'is-correct' : 'is-wrong'}">
        <div class="card-body p-4">
          <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
            <div class="d-flex align-items-start gap-3">
              <span class="question-number">${i + 1}</span>
              <div>
                <p class="question-meta mb-1">Tema ${Number(q.tema)} · ${escapeHtml(q.referencia)} ${renderQuestionTags(q)} ${failBadge}</p>
                <h3 class="h5 mb-0">${escapeHtml(q.pregunta)}</h3>
              </div>
            </div>
            ${doubtButton}
          </div>
          <div class="correction-answer ${correct ? 'text-success' : 'text-danger'} fw-semibold mb-2">
            ${correct ? 'Correcta' : 'Incorrecta'}
          </div>
          <dl class="row mb-0 g-2">
            <dt class="col-sm-3 text-body-secondary">Tu respuesta</dt>
            <dd class="col-sm-9">${pick >= 0 ? escapeHtml(q.opciones[pick]) : '<span class="text-body-secondary">Sin responder</span>'}</dd>
            <dt class="col-sm-3 text-body-secondary">Correcta</dt>
            <dd class="col-sm-9">${escapeHtml(q.opciones[q.correcta])}</dd>
          </dl>
        </div>
      </article>`;
  }

  function loadFailsView() {
    const fails = readFails()
      .map((item, index) => normalizeQuestion(item, Number(item?.tema ?? 0), index))
      .filter(Boolean);
    const { nuevos, recurrentes } = getFailBuckets(fails);

    root.innerHTML = `
      <div class="test-hero mb-4">
        <span class="test-kicker">Fallos</span>
        <h2 class="display-6 mb-2">Repetir fallos</h2>
        <p class="text-body-secondary mb-3">Practica solo las preguntas que hayas fallado antes. Las recurrentes se priorizan para atacar primero lo que más se resiste.</p>
        <div class="d-flex flex-wrap gap-2">
          <span class="badge text-bg-secondary">Nuevos: ${nuevos.length}</span>
          <span class="badge text-bg-warning">Recurrentes: ${recurrentes.length}</span>
        </div>
      </div>
      <div class="test-config">
        <div class="test-panel">
          <label class="form-label fw-semibold" for="fail-filter">Bloque a repasar</label>
          <select class="form-select mb-3" id="fail-filter">
            <option value="mixed" ${currentFailFilter === 'mixed' ? 'selected' : ''}>Mixto priorizando recurrentes</option>
            <option value="recurrent" ${currentFailFilter === 'recurrent' ? 'selected' : ''}>Solo recurrentes</option>
            <option value="new" ${currentFailFilter === 'new' ? 'selected' : ''}>Solo nuevos fallos</option>
          </select>
          <label class="form-label fw-semibold" for="limit">Número de preguntas</label>
          <select class="form-select" id="limit">${failLimitOptions.map((n) => `<option value="${n}" ${n === 0 ? 'selected' : ''}>${n === 0 ? 'Todas' : n}</option>`).join('')}</select>
          <button id="start" class="btn btn-primary btn-lg w-100 mt-3" type="button">Empezar repaso</button>
        </div>
      </div>`;

    document.getElementById('start')?.addEventListener('click', () => {
      currentFailFilter = document.getElementById('fail-filter')?.value ?? 'mixed';
      startTest(Number(document.getElementById('limit')?.value ?? '0'));
    });
  }

  function loadDoubtsView() {
    const doubts = readDoubts()
      .map((item, index) => normalizeQuestion(item, Number(item?.tema ?? 0), index))
      .filter(Boolean);
    const { nuevas, recurrentes } = getDoubtBuckets(doubts);

    root.innerHTML = `
      <div class="test-hero mb-4">
        <span class="test-kicker">Dudosas</span>
        <h2 class="display-6 mb-2">Revisar preguntas marcadas</h2>
        <p class="text-body-secondary mb-3">Aquí van las preguntas que has marcado porque no te convencen, son ambiguas o quieres revisarlas mejor.</p>
        <div class="d-flex flex-wrap gap-2">
          <span class="badge text-bg-secondary">Marcadas: ${doubts.length}</span>
          <span class="badge text-bg-warning">Con fallos recurrentes: ${recurrentes.length}</span>
          <span class="badge text-bg-primary">Solo duda tecnica: ${nuevas.length}</span>
        </div>
      </div>
      <div class="test-config">
        <div class="test-panel">
          <label class="form-label fw-semibold" for="doubt-filter">Bloque a revisar</label>
          <select class="form-select mb-3" id="doubt-filter">
            <option value="mixed" ${currentDoubtFilter === 'mixed' ? 'selected' : ''}>Mixto priorizando conflictivas</option>
            <option value="recurrent" ${currentDoubtFilter === 'recurrent' ? 'selected' : ''}>Solo dudosas con fallos recurrentes</option>
            <option value="new" ${currentDoubtFilter === 'new' ? 'selected' : ''}>Solo dudosas nuevas</option>
          </select>
          <label class="form-label fw-semibold" for="limit">Número de preguntas</label>
          <select class="form-select" id="limit">${failLimitOptions.map((n) => `<option value="${n}" ${n === 0 ? 'selected' : ''}>${n === 0 ? 'Todas' : n}</option>`).join('')}</select>
          <button id="start" class="btn btn-primary btn-lg w-100 mt-3" type="button">Empezar revision</button>
        </div>
      </div>`;

    document.getElementById('start')?.addEventListener('click', () => {
      currentDoubtFilter = document.getElementById('doubt-filter')?.value ?? 'mixed';
      startTest(Number(document.getElementById('limit')?.value ?? '0'));
    });
  }

  if (mode === 'fails') {
    loadFailsView();
  } else if (mode === 'doubts') {
    loadDoubtsView();
  } else {
    loadNormalQuestions();
  }
</script>
