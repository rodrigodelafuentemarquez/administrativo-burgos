<script>
  const KEY = 'oposicion-access-ok-v1';
  const USER = 'rodrigo';
  const PASS = 'xof13odi';

  function showGate() {
    const overlay = document.createElement('div');
    overlay.setAttribute('id', 'access-gate');
    overlay.setAttribute('class', 'position-fixed top-0 start-0 w-100 h-100 d-grid align-items-center bg-body');
    overlay.setAttribute('style', 'z-index:9999;padding:1rem;');
    overlay.innerHTML = `
      <form class="card shadow-sm border-0 mx-auto p-4" style="max-width:380px;width:100%;" id="gate-form">
        <div class="d-flex align-items-center mb-3">
          <span class="bd-brand-mark me-2">B</span>
          <h1 class="h4 mb-0">Acceso</h1>
        </div>
        <p class="text-body-secondary mb-3">Zona de estudio privada.</p>
        <div class="mb-3">
          <label class="form-label" for="gate-user">Usuario</label>
          <input class="form-control" required id="gate-user" name="u" />
        </div>
        <div class="mb-3">
          <label class="form-label" for="gate-pass">Contraseña</label>
          <input class="form-control" required id="gate-pass" name="p" type="password" />
        </div>
        <button class="btn btn-primary w-100" type="submit">Entrar</button>
        <p id="gate-error" class="text-danger small mt-3 mb-0" style="min-height:1.2em"></p>
      </form>`;
    document.body.appendChild(overlay);

    overlay.querySelector('#gate-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const u = String(fd.get('u') ?? '');
      const p = String(fd.get('p') ?? '');
      if (u === USER && p === PASS) {
        localStorage.setItem(KEY, '1');
        overlay.remove();
      } else {
        const err = overlay.querySelector('#gate-error');
        if (err) err.textContent = 'Credenciales incorrectas';
      }
    });
  }

  if (typeof localStorage !== 'undefined') {
    if (localStorage.getItem(KEY) !== '1') showGate();
  }
</script>
