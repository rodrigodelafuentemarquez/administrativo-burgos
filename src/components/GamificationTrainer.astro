---
import { gameGroups } from '../data/gamification';
import { constitutionQuestions } from '../data/constitutionGames';
import { errorHuntItems } from '../data/errorHuntGames';
import { guidedCases } from '../data/guidedCases';
import { practicalSimulators } from '../data/practicalSimulators';

const gameData = JSON.stringify(gameGroups);
const constitutionData = JSON.stringify(constitutionQuestions);
const errorData = JSON.stringify(errorHuntItems);
const caseData = JSON.stringify(guidedCases);
const simulatorData = JSON.stringify(practicalSimulators);
---

<section
  class="game-shell"
  data-game-groups={gameData}
  data-constitution-games={constitutionData}
  data-error-games={errorData}
  data-guided-cases={caseData}
  data-practical-simulators={simulatorData}
>
  <div class="game-hero">
    <div>
      <span class="game-kicker">Repaso activo</span>
      <h1>Juegos de memoria por grupos</h1>
      <p>Asocia conceptos, revela huecos y ordena secuencias sin salir del temario oficial.</p>
    </div>
    <div class="game-score" aria-live="polite">
      <strong id="game-score-value">0/0</strong>
      <span id="game-score-label">Elige un modo</span>
    </div>
  </div>

  <div class="game-controls" aria-label="Configuración del juego">
    <label>
      <span>Grupo</span>
      <select id="game-group" class="form-select form-select-lg">
        {gameGroups.map((group) => (
          <option value={group.id}>{group.label}</option>
        ))}
      </select>
    </label>
    <label>
      <span>Modo</span>
      <select id="game-mode" class="form-select form-select-lg">
        <option value="matches">Parejas</option>
        <option value="fills">Completar huecos</option>
        <option value="orders">Ordenar</option>
        <option value="constitution">Constitución intensiva</option>
        <option value="errors">Detecta el error</option>
        <option value="cases">Casos guiados</option>
        <option value="simulators">Simuladores prácticos</option>
      </select>
    </label>
    <button id="game-reset" class="btn btn-primary btn-lg" type="button">Nueva partida</button>
  </div>

  <section class="game-board" id="game-board" aria-live="polite"></section>
</section>

<script>
  const shell = document.querySelector('.game-shell');
  const groups = JSON.parse(shell?.getAttribute('data-game-groups') ?? '[]');
  const constitutionGames = JSON.parse(shell?.getAttribute('data-constitution-games') ?? '[]');
  const errorGames = JSON.parse(shell?.getAttribute('data-error-games') ?? '[]');
  const guidedCaseGames = JSON.parse(shell?.getAttribute('data-guided-cases') ?? '[]');
  const practicalSimulatorGames = JSON.parse(shell?.getAttribute('data-practical-simulators') ?? '[]');
  const groupSelect = document.getElementById('game-group');
  const modeSelect = document.getElementById('game-mode');
  const resetButton = document.getElementById('game-reset');
  const board = document.getElementById('game-board');
  const scoreValue = document.getElementById('game-score-value');
  const scoreLabel = document.getElementById('game-score-label');

  let selectedLeftId = null;
  let activeOrderItems = [];
  let activeOrder = null;
  let activeGuidedCase = null;
  let activeGuidedStep = 0;
  let activeGuidedCorrect = 0;

  const escapeHtml = (value) => String(value ?? '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');

  const shuffle = (items) => items
    .map((item) => ({ item, sort: Math.random() }))
    .sort((a, b) => a.sort - b.sort)
    .map(({ item }) => item);

  function currentGroup() {
    return groups.find((group) => group.id === groupSelect?.value) ?? groups[0];
  }

  function currentMode() {
    return modeSelect?.value ?? 'matches';
  }

  function setScore(value, label) {
    if (scoreValue) scoreValue.textContent = value;
    if (scoreLabel) scoreLabel.textContent = label;
  }

  function renderIntro(group, modeTitle) {
    return `
      <div class="game-board-head">
        <div>
          <span class="game-kicker">${escapeHtml(group.label)}</span>
          <h2>${escapeHtml(modeTitle)}</h2>
          <p>${escapeHtml(group.summary)}</p>
        </div>
      </div>
    `;
  }

  function renderModeIntro(label, modeTitle, summary) {
    return `
      <div class="game-board-head">
        <div>
          <span class="game-kicker">${escapeHtml(label)}</span>
          <h2>${escapeHtml(modeTitle)}</h2>
          <p>${escapeHtml(summary)}</p>
        </div>
      </div>
    `;
  }

  function updateMatchScore() {
    const total = board?.querySelectorAll('[data-left-id]').length ?? 0;
    const matched = board?.querySelectorAll('[data-left-id].is-correct').length ?? 0;
    setScore(`${matched}/${total}`, matched === total && total > 0 ? 'Partida completada' : 'Parejas correctas');
  }

  function renderMatches() {
    const group = currentGroup();
    selectedLeftId = null;
    const cards = shuffle(group.matches).slice(0, 8);
    const rightCards = shuffle(cards);
    setScore(`0/${cards.length}`, 'Parejas correctas');

    board.innerHTML = `
      ${renderIntro(group, 'Une cada término con su idea')}
      <div class="game-help">Toca primero un término de la izquierda y después su pareja de la derecha.</div>
      <div class="match-layout">
        <div class="match-column" aria-label="Términos">
          ${cards.map((card) => `
            <button class="match-card" type="button" data-left-id="${escapeHtml(card.id)}">
              <span>${escapeHtml(card.left)}</span>
              <small>${escapeHtml(card.tag)}</small>
            </button>
          `).join('')}
        </div>
        <div class="match-column" aria-label="Definiciones">
          ${rightCards.map((card) => `
            <button class="match-card" type="button" data-right-id="${escapeHtml(card.id)}">
              <span>${escapeHtml(card.right)}</span>
            </button>
          `).join('')}
        </div>
      </div>
    `;
  }

  function renderFills() {
    const group = currentGroup();
    const cards = shuffle(group.fills);
    setScore(`0/${cards.length}`, 'Huecos revelados');

    board.innerHTML = `
      ${renderIntro(group, 'Completa mentalmente y toca el hueco')}
      <div class="game-help">Piensa la respuesta. Cuando la tengas, toca el hueco y se rellenará con la solución correcta.</div>
      <div class="fill-list">
        ${cards.map((card) => `
          <article class="fill-card" data-fill-id="${escapeHtml(card.id)}">
            <span class="badge text-bg-dark">${escapeHtml(card.tag)}</span>
            <p>
              ${escapeHtml(card.before)}
              <button class="blank-button" type="button" data-answer="${escapeHtml(card.answer)}" aria-label="Mostrar respuesta">__________</button>
              ${escapeHtml(card.after)}
            </p>
          </article>
        `).join('')}
      </div>
      <div class="game-actions">
        <button class="btn btn-outline-light" type="button" data-reveal-all>Ver todas las respuestas</button>
      </div>
    `;
  }

  function updateFillScore() {
    const total = board?.querySelectorAll('.blank-button').length ?? 0;
    const revealed = board?.querySelectorAll('.blank-button.is-revealed').length ?? 0;
    setScore(`${revealed}/${total}`, revealed === total && total > 0 ? 'Todas visibles' : 'Huecos revelados');
  }

  function renderOrderItems(items, checked = false) {
    const expected = activeOrder?.items ?? [];
    return items.map((item, index) => {
      const correctClass = checked ? (item === expected[index] ? 'is-correct' : 'is-wrong') : '';
      return `
        <li class="order-item ${correctClass}" data-order-index="${index}">
          <span class="order-number">${index + 1}</span>
          <span>${escapeHtml(item)}</span>
          <span class="order-buttons">
            <button class="btn btn-sm btn-outline-light" type="button" data-move="up" aria-label="Subir">↑</button>
            <button class="btn btn-sm btn-outline-light" type="button" data-move="down" aria-label="Bajar">↓</button>
          </span>
        </li>
      `;
    }).join('');
  }

  function updateOrderList(checked = false) {
    const list = board?.querySelector('.order-list');
    if (!list) return;
    list.innerHTML = renderOrderItems(activeOrderItems, checked);
  }

  function renderOrders() {
    const group = currentGroup();
    activeOrder = shuffle(group.orders)[0];
    activeOrderItems = shuffle(activeOrder.items);
    setScore('0/1', 'Secuencia pendiente');

    board.innerHTML = `
      ${renderIntro(group, 'Ordena la secuencia')}
      <div class="game-help">Usa las flechas para colocar cada paso en su sitio. Después corrige o muestra la solución.</div>
      <article class="order-card">
        <span class="badge text-bg-dark">${escapeHtml(activeOrder.tag)}</span>
        <h3>${escapeHtml(activeOrder.title)}</h3>
        <ol class="order-list">
          ${renderOrderItems(activeOrderItems)}
        </ol>
        <div class="game-actions">
          <button class="btn btn-primary" type="button" data-check-order>Corregir</button>
          <button class="btn btn-outline-light" type="button" data-show-order>Ver respuesta</button>
        </div>
      </article>
    `;
  }

  function renderChoiceExercise(items, config) {
    const cards = shuffle(items).slice(0, config.limit);
    setScore(`0/${cards.length}`, config.scoreLabel);

    board.innerHTML = `
      ${renderModeIntro(config.label, config.title, config.summary)}
      <div class="game-help">${escapeHtml(config.help)}</div>
      <div class="quiz-list">
        ${cards.map((item) => {
          const answer = item.answer;
          const options = shuffle(item.options);
          return `
            <article class="quiz-card" data-quiz-card>
              <div class="quiz-card__top">
                <span class="badge text-bg-dark">${escapeHtml(item.tag)}</span>
              </div>
              <h3>${escapeHtml(item.prompt ?? item.statement)}</h3>
              <div class="choice-grid">
                ${options.map((option) => `
                  <button class="choice-option" type="button" data-choice-option data-correct="${option === answer ? 'true' : 'false'}">
                    ${escapeHtml(option)}
                  </button>
                `).join('')}
              </div>
              <p class="quiz-explanation" hidden>${escapeHtml(item.explanation)}</p>
            </article>
          `;
        }).join('')}
      </div>
    `;
  }

  function updateChoiceScore(label) {
    const total = board?.querySelectorAll('[data-quiz-card]').length ?? 0;
    const correct = board?.querySelectorAll('[data-quiz-card].is-correct').length ?? 0;
    setScore(`${correct}/${total}`, correct === total && total > 0 ? 'Bloque perfecto' : label);
  }

  function renderConstitution() {
    renderChoiceExercise(constitutionGames, {
      label: 'Constitución',
      title: 'Artículos, títulos y garantías',
      summary: 'Entrena reconocimiento rápido: artículo, materia, bloque constitucional y protección de derechos.',
      help: 'Toca la respuesta correcta. Cada tarjeta muestra la explicación al responder.',
      limit: 10,
      scoreLabel: 'Aciertos constitucionales',
    });
  }

  function renderErrors() {
    const group = currentGroup();
    const items = errorGames.filter((item) => item.groupId === group.id);
    renderChoiceExercise(items, {
      label: group.label,
      title: 'Detecta el error',
      summary: 'Frases con trampas de examen: plazo, órgano, norma, trámite o concepto.',
      help: 'Lee la frase y marca qué tipo de error contiene. Después verás la explicación.',
      limit: 8,
      scoreLabel: 'Errores detectados',
    });
  }

  function renderGuidedCaseStep() {
    if (!activeGuidedCase) return;
    const step = activeGuidedCase.steps[activeGuidedStep];
    const total = activeGuidedCase.steps.length;
    setScore(`${activeGuidedCorrect}/${total}`, `Paso ${activeGuidedStep + 1}/${total}`);

    board.innerHTML = `
      ${renderModeIntro(currentGroup().label, 'Caso guiado', 'Supuestos cortos con decisiones encadenadas para entrenar razonamiento de examen.')}
      <article class="case-card">
        <div class="quiz-card__top">
          <span class="badge text-bg-dark">${escapeHtml(activeGuidedCase.tag)}</span>
          <span class="badge text-bg-secondary">${escapeHtml(activeGuidedCase.difficulty)}</span>
        </div>
        <h3>${escapeHtml(activeGuidedCase.title)}</h3>
        <p>${escapeHtml(activeGuidedCase.scenario)}</p>
        <div class="case-step">
          <strong>Paso ${activeGuidedStep + 1} de ${total}</strong>
          <h4>${escapeHtml(step.prompt)}</h4>
          <div class="choice-grid">
            ${shuffle(step.options).map((option) => `
              <button class="choice-option" type="button" data-case-option data-correct="${option === step.answer ? 'true' : 'false'}">
                ${escapeHtml(option)}
              </button>
            `).join('')}
          </div>
          <p class="quiz-explanation" hidden>${escapeHtml(step.explanation)}</p>
          <div class="game-actions case-next-row" hidden>
            <button class="btn btn-primary" type="button" data-next-case-step>
              ${activeGuidedStep + 1 >= total ? 'Nuevo caso' : 'Siguiente paso'}
            </button>
          </div>
        </div>
      </article>
    `;
  }

  function renderCases() {
    const group = currentGroup();
    const cases = guidedCaseGames.filter((item) => item.groupId === group.id);
    activeGuidedCase = shuffle(cases)[0];
    activeGuidedStep = 0;
    activeGuidedCorrect = 0;
    renderGuidedCaseStep();
  }

  function renderSimulators() {
    const group = currentGroup();
    const simulators = practicalSimulatorGames.filter((item) => item.groupId === group.id);
    const simulator = shuffle(simulators)[0];
    if (!simulator) {
      board.innerHTML = `${renderModeIntro(group.label, 'Simuladores prácticos', 'Todavía no hay simuladores para este grupo.')}`;
      setScore('0/0', 'Sin simuladores');
      return;
    }
    setScore(`${simulator.questions.length}`, 'Preguntas prácticas');

    board.innerHTML = `
      ${renderModeIntro(group.label, 'Simulador práctico', 'Lee el supuesto, revisa los datos relevantes y revela respuestas como si corrigieras tu propio esquema.')}
      <article class="case-card">
        <div class="quiz-card__top">
          <span class="badge text-bg-dark">${escapeHtml(simulator.tag)}</span>
          <span class="badge text-bg-secondary">${escapeHtml(simulator.difficulty)}</span>
        </div>
        <h3>${escapeHtml(simulator.title)}</h3>
        <p>${escapeHtml(simulator.scenario)}</p>
        <section class="sim-checklist">
          <h4>Checklist del supuesto</h4>
          <ul>
            ${simulator.checklist.map((item) => `<li>${escapeHtml(item)}</li>`).join('')}
          </ul>
        </section>
        <div class="sim-question-list">
          ${simulator.questions.map((question, index) => `
            <article class="sim-question">
              <h4>${index + 1}. ${escapeHtml(question.prompt)}</h4>
              <button class="btn btn-outline-light" type="button" data-reveal-sim-answer>Ver respuesta</button>
              <p class="quiz-explanation" hidden>${escapeHtml(question.answer)}</p>
            </article>
          `).join('')}
        </div>
        <div class="game-actions">
          <button class="btn btn-primary" type="button" data-reveal-sim-solution>Ver solución completa</button>
          <button class="btn btn-outline-light" type="button" data-new-simulator>Nuevo supuesto</button>
        </div>
        <p class="quiz-explanation sim-solution" hidden>${escapeHtml(simulator.solution)}</p>
      </article>
    `;
  }

  function renderGame() {
    const mode = currentMode();
    activeGuidedCase = null;
    if (mode === 'fills') {
      renderFills();
      return;
    }
    if (mode === 'orders') {
      renderOrders();
      return;
    }
    if (mode === 'constitution') {
      renderConstitution();
      return;
    }
    if (mode === 'errors') {
      renderErrors();
      return;
    }
    if (mode === 'cases') {
      renderCases();
      return;
    }
    if (mode === 'simulators') {
      renderSimulators();
      return;
    }
    renderMatches();
  }

  board?.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const leftButton = target.closest('[data-left-id]');
    if (leftButton && !leftButton.classList.contains('is-correct')) {
      board.querySelectorAll('[data-left-id].is-selected').forEach((item) => item.classList.remove('is-selected'));
      leftButton.classList.add('is-selected');
      selectedLeftId = leftButton.getAttribute('data-left-id');
      return;
    }

    const rightButton = target.closest('[data-right-id]');
    if (rightButton && selectedLeftId && !rightButton.classList.contains('is-correct')) {
      const rightId = rightButton.getAttribute('data-right-id');
      const left = board.querySelector(`[data-left-id="${CSS.escape(selectedLeftId)}"]`);
      if (rightId === selectedLeftId) {
        left?.classList.remove('is-selected');
        left?.classList.add('is-correct');
        rightButton.classList.add('is-correct');
        selectedLeftId = null;
        updateMatchScore();
      } else {
        left?.classList.add('is-wrong');
        rightButton.classList.add('is-wrong');
        window.setTimeout(() => {
          left?.classList.remove('is-wrong');
          rightButton.classList.remove('is-wrong');
        }, 650);
      }
      return;
    }

    const blank = target.closest('.blank-button');
    if (blank && !blank.classList.contains('is-revealed')) {
      blank.textContent = blank.getAttribute('data-answer') ?? '';
      blank.classList.add('is-revealed');
      updateFillScore();
      return;
    }

    if (target.closest('[data-reveal-all]')) {
      board.querySelectorAll('.blank-button').forEach((button) => {
        button.textContent = button.getAttribute('data-answer') ?? '';
        button.classList.add('is-revealed');
      });
      updateFillScore();
      return;
    }

    const moveButton = target.closest('[data-move]');
    if (moveButton) {
      const item = moveButton.closest('[data-order-index]');
      const from = Number(item?.getAttribute('data-order-index'));
      const direction = moveButton.getAttribute('data-move') === 'up' ? -1 : 1;
      const to = from + direction;
      if (to < 0 || to >= activeOrderItems.length) return;
      const next = [...activeOrderItems];
      [next[from], next[to]] = [next[to], next[from]];
      activeOrderItems = next;
      updateOrderList();
      setScore('0/1', 'Secuencia pendiente');
      return;
    }

    if (target.closest('[data-check-order]')) {
      const correct = activeOrderItems.every((item, index) => item === activeOrder.items[index]);
      updateOrderList(true);
      setScore(correct ? '1/1' : '0/1', correct ? 'Secuencia correcta' : 'Revisa las posiciones marcadas');
      return;
    }

    if (target.closest('[data-show-order]')) {
      activeOrderItems = [...activeOrder.items];
      updateOrderList(true);
      setScore('1/1', 'Respuesta visible');
      return;
    }

    const choice = target.closest('[data-choice-option]');
    if (choice) {
      const card = choice.closest('[data-quiz-card]');
      if (!card || card.classList.contains('is-answered')) return;
      const isCorrect = choice.getAttribute('data-correct') === 'true';
      card.classList.add('is-answered', isCorrect ? 'is-correct' : 'is-wrong');
      card.querySelectorAll('[data-choice-option]').forEach((button) => {
        button.disabled = true;
        if (button.getAttribute('data-correct') === 'true') button.classList.add('is-correct');
      });
      choice.classList.add(isCorrect ? 'is-correct' : 'is-wrong');
      const explanation = card.querySelector('.quiz-explanation');
      if (explanation) explanation.hidden = false;
      updateChoiceScore(currentMode() === 'errors' ? 'Errores detectados' : 'Aciertos constitucionales');
      return;
    }

    const caseChoice = target.closest('[data-case-option]');
    if (caseChoice) {
      const step = caseChoice.closest('.case-step');
      if (!step || step.classList.contains('is-answered')) return;
      const isCorrect = caseChoice.getAttribute('data-correct') === 'true';
      if (isCorrect) activeGuidedCorrect += 1;
      step.classList.add('is-answered');
      step.querySelectorAll('[data-case-option]').forEach((button) => {
        button.disabled = true;
        if (button.getAttribute('data-correct') === 'true') button.classList.add('is-correct');
      });
      caseChoice.classList.add(isCorrect ? 'is-correct' : 'is-wrong');
      const explanation = step.querySelector('.quiz-explanation');
      const nextRow = step.querySelector('.case-next-row');
      if (explanation) explanation.hidden = false;
      if (nextRow) nextRow.hidden = false;
      setScore(`${activeGuidedCorrect}/${activeGuidedCase.steps.length}`, isCorrect ? 'Paso correcto' : 'Revisa este paso');
      return;
    }

    if (target.closest('[data-next-case-step]')) {
      if (!activeGuidedCase) return;
      activeGuidedStep += 1;
      if (activeGuidedStep >= activeGuidedCase.steps.length) {
        renderCases();
        return;
      }
      renderGuidedCaseStep();
      return;
    }

    if (target.closest('[data-reveal-sim-answer]')) {
      const parent = target.closest('.sim-question');
      const explanation = parent?.querySelector('.quiz-explanation');
      if (explanation) explanation.hidden = false;
      target.disabled = true;
      return;
    }

    if (target.closest('[data-reveal-sim-solution]')) {
      const solution = board.querySelector('.sim-solution');
      if (solution) solution.hidden = false;
      return;
    }

    if (target.closest('[data-new-simulator]')) {
      renderSimulators();
    }
  });

  groupSelect?.addEventListener('change', renderGame);
  modeSelect?.addEventListener('change', renderGame);
  resetButton?.addEventListener('click', renderGame);

  renderGame();
</script>

<style is:global>
  .game-shell {
    display: grid;
    gap: 1rem;
  }

  .game-hero,
  .game-controls,
  .game-board,
  .game-card,
  .fill-card,
  .order-card,
  .quiz-card,
  .case-card,
  .sim-question {
    min-width: 0;
  }

  .game-hero {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--bs-border-color);
    border-radius: .5rem;
    background: var(--bs-tertiary-bg);
  }

  .game-hero h1,
  .game-board h2,
  .order-card h3 {
    margin: .35rem 0 .35rem;
    line-height: 1.15;
  }

  .game-hero p,
  .game-board-head p {
    margin: 0;
    color: var(--bs-secondary-color);
  }

  .game-kicker {
    display: inline-flex;
    width: fit-content;
    padding: .2rem .5rem;
    color: var(--bd-accent);
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    background: rgba(var(--bd-violet-rgb), .25);
    border-radius: .35rem;
  }

  .game-score {
    display: grid;
    align-content: center;
    min-height: 5rem;
    padding: .8rem;
    border: 1px solid rgba(var(--bd-accent-rgb), .35);
    border-radius: .5rem;
    background: rgba(var(--bd-accent-rgb), .06);
  }

  .game-score strong {
    color: var(--bs-emphasis-color);
    font-size: 1.65rem;
    line-height: 1;
  }

  .game-score span {
    color: var(--bs-secondary-color);
    font-size: .9rem;
  }

  .game-controls {
    display: grid;
    gap: .75rem;
    padding: 1rem;
    border: 1px solid var(--bs-border-color);
    border-radius: .5rem;
    background: rgba(255, 255, 255, .025);
  }

  .game-controls label {
    display: grid;
    gap: .3rem;
    font-weight: 700;
  }

  .game-controls .btn,
  .game-actions .btn,
  .sim-question .btn {
    min-height: 2.75rem;
  }

  .game-controls label span {
    color: var(--bs-secondary-color);
    font-size: .8rem;
    text-transform: uppercase;
  }

  .game-board {
    display: grid;
