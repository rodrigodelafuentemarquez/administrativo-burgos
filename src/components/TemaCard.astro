---
interface Props { tema: number; titulo: string; slug: string; }
const { tema, titulo, slug } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<a
  href={`${base}temas/${slug}`}
  class="card tema-btn"
  style="display:block; text-decoration:none; color:var(--fg);"
>
  <h2 style="margin:.1rem 0 .3rem; font-size:1rem;">Tema {tema}</h2>
  <p class="muted" style="margin:0; line-height:1.35">{titulo}</p>
</a>
