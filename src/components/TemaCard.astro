---
interface Props { tema: number; titulo: string; slug: string; }
const { tema, titulo, slug } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<a
  href={`${base}temas/${slug}`}
  class="card tema-btn btn btn-outline-secondary text-start p-3 w-100"
  style="display:block; text-decoration:none;"
>
  <h2 style="margin:.1rem 0 .3rem; font-size:1rem;">Tema {tema}</h2>
  <p class="muted mb-0" style="line-height:1.35">{titulo}</p>
</a>
