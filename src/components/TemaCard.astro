---
interface Props { tema: number; titulo: string; slug: string; }
const { tema, titulo, slug } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<a
  href={`${base}temas/${slug}`}
  class="list-group-item list-group-item-action p-3"
  style="display:block; text-decoration:none;"
>
  <div class="fw-semibold">Tema {tema}</div>
  <p class="text-body-secondary mb-0" style="line-height:1.35">{titulo}</p>
</a>
