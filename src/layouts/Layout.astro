---
import { getCollection } from 'astro:content';
interface Props {
  title: string;
}
const { title } = Astro.props;
import AccessGate from '../components/AccessGate.astro';
const temas = (await getCollection('temas')).sort((a, b) => a.data.tema - b.data.tema);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e7490" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}icons/icon-192.png`} sizes="192x192" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <title>{title}</title>
    <script>
      (() => {
        const saved = localStorage.getItem('oposicion-theme') || 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = saved === 'system' ? (prefersDark ? 'dark' : 'light') : saved;
        document.documentElement.setAttribute('data-bs-theme', resolved);
      })();
    </script>
    <style>
      :root { --app-bg: #f4f4f1; --app-fg: #1f2328; }
      :root[data-bs-theme="dark"] { --app-bg: #111111; --app-fg: #f1f3f5; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
        background: var(--app-bg);
        color: var(--app-fg);
      }
      main { max-width: 980px; margin: 0 auto; padding: 1rem; }
      .topbar {
        position: sticky;
        top: 0;
        z-index: 40;
      }
      .brand { font-weight: 700; letter-spacing: .2px; text-decoration: none; color: inherit; }
      .actions { display:flex; gap:.5rem; align-items:center; }
      .card { border-radius: .8rem; }
      .grid { display:grid; gap:.75rem; }
      @media (min-width:700px){ .grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
      .muted { opacity: .85; }
      .panel {
        position: fixed;
        top:0;
        bottom:0;
        width:min(86vw, 330px);
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        padding:1rem;
        overflow:auto;
        z-index:60;
        box-shadow: 0 0.75rem 2rem rgba(0,0,0,.2);
        transform: translateX(-105%);
        transition: transform .2s ease;
      }
      .panel.right { right:0; left:auto; transform: translateX(105%); }
      .panel.open { transform: translateX(0); }
      .panel h2 { margin:.3rem 0 .8rem; font-size:1rem; }
      .panel a { display:block; padding:.45rem 0; border-bottom:1px dashed var(--bs-border-color); text-decoration: none; }
      .backdrop {
        position:fixed;
        inset:0;
        background:rgba(2, 8, 23, .45);
        z-index:55;
        display:none;
      }
      .backdrop.show { display:block; }
      .tema-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        display: block;
        overflow-x: auto;
      }
      .tema-content th,
      .tema-content td {
        border: 1px solid var(--bs-border-color);
        padding: .55rem .65rem;
        vertical-align: top;
      }
      .tema-content th {
        background: color-mix(in srgb, var(--bs-body-color) 6%, transparent);
      }
      .tema-content h2,
      .tema-content h3 { margin-top: 1.35rem; }
    </style>
  </head>
  <body>
    <header class="topbar border-bottom bg-body">
      <div class="actions">
        <button id="open-main-menu" class="btn btn-outline-secondary btn-sm" aria-label="Abrir menú principal">Menu</button>
        <a class="brand" href={base}>Oposición Burgos</a>
      </div>
      <div class="actions">
        <select id="theme-picker" class="form-select form-select-sm" aria-label="Elegir tema visual">
          <option value="system">Sistema</option>
          <option value="light">Claro</option>
          <option value="dark">Oscuro</option>
        </select>
        <button id="open-topics-menu" class="btn btn-outline-secondary btn-sm" aria-label="Abrir menú de temas">Temas</button>
      </div>
    </header>

    <aside class="panel" id="main-panel">
      <h2>Estudio</h2>
      <a href={base}>Inicio</a>
      <a href={`${base}test`}>Hacer test</a>
      <a href={`${base}fallos`}>Repetir fallos</a>
      <a href={`${base}progreso`}>Progreso</a>
    </aside>

    <aside class="panel right" id="topics-panel">
      <h2>Temas</h2>
      {temas.map((t) => (
        <a href={`${base}temas/${t.id.replace(/\.md$/, '')}`}>
          Tema {t.data.tema}
        </a>
      ))}
    </aside>
    <div class="backdrop" id="menu-backdrop"></div>

    <main>
      <slot />
    </main>
    <AccessGate />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register(`${base}sw.js`));
      }

      const root = document.documentElement;
      const picker = document.getElementById('theme-picker');
      const saved = localStorage.getItem('oposicion-theme') || 'system';
      picker.value = saved;
      const applyTheme = (mode) => {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
        root.setAttribute('data-bs-theme', resolved);
      };
      applyTheme(saved);
      picker?.addEventListener('change', () => {
        localStorage.setItem('oposicion-theme', picker.value);
        applyTheme(picker.value);
      });

      const mainPanel = document.getElementById('main-panel');
      const topicsPanel = document.getElementById('topics-panel');
      const backdrop = document.getElementById('menu-backdrop');
      const closeAll = () => {
        mainPanel?.classList.remove('open');
        topicsPanel?.classList.remove('open');
        backdrop?.classList.remove('show');
      };
      document.getElementById('open-main-menu')?.addEventListener('click', () => {
        mainPanel?.classList.add('open');
        topicsPanel?.classList.remove('open');
        backdrop?.classList.add('show');
      });
      document.getElementById('open-topics-menu')?.addEventListener('click', () => {
        topicsPanel?.classList.add('open');
        mainPanel?.classList.remove('open');
        backdrop?.classList.add('show');
      });
      backdrop?.addEventListener('click', closeAll);
    </script>
  </body>
</html>
