---
import { getCollection } from 'astro:content';
interface Props {
  title: string;
}
const { title } = Astro.props;
import AccessGate from '../components/AccessGate.astro';
const temas = (await getCollection('temas')).sort((a, b) => a.data.tema - b.data.tema);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e7490" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}icons/icon-192.png`} sizes="192x192" />
    <title>{title}</title>
    <script>
      (() => {
        const saved = localStorage.getItem('oposicion-theme') || 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = saved === 'system' ? (prefersDark ? 'dark' : 'light') : saved;
        document.documentElement.dataset.theme = resolved;
      })();
    </script>
    <style>
      :root {
        --bg:#f7fafc;
        --bg-soft:#eef3f8;
        --fg:#0f172a;
        --muted:#475569;
        --card:#ffffff;
        --accent:#0f766e;
        --accent-2:#0ea5e9;
        --border:#dbe3ec;
        --shadow:0 8px 24px rgba(15, 23, 42, 0.08);
      }
      :root[data-theme="dark"] {
        --bg:#0b1220;
        --bg-soft:#111a2e;
        --fg:#e2e8f0;
        --muted:#94a3b8;
        --card:#111827;
        --accent:#34d399;
        --accent-2:#38bdf8;
        --border:#2a364d;
        --shadow:0 10px 24px rgba(2, 8, 23, 0.35);
      }
      * { box-sizing: border-box; }
      body {
        margin:0;
        font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
        background:
          radial-gradient(1000px 500px at 10% -10%, color-mix(in srgb, var(--accent-2) 14%, transparent), transparent),
          radial-gradient(900px 500px at 100% 0%, color-mix(in srgb, var(--accent) 12%, transparent), transparent),
          var(--bg);
        color:var(--fg);
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      main { max-width: 980px; margin: 0 auto; padding: 1rem; }
      .topbar {
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:.7rem;
        padding: .8rem 1rem;
        border-bottom:1px solid var(--border);
        background: color-mix(in srgb, var(--card) 92%, transparent);
        backdrop-filter: blur(8px);
        position:sticky;
        top:0;
        z-index:40;
      }
      .brand { font-weight:700; font-size: 1rem; letter-spacing:.2px; }
      .actions { display:flex; gap:.5rem; align-items:center; }
      .card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:1rem; box-shadow: var(--shadow); }
      .grid { display:grid; gap:.75rem; }
      @media (min-width:700px){ .grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
      button, select { font: inherit; padding:.6rem .75rem; border-radius:.6rem; border:1px solid var(--border); background:var(--card); color:var(--fg); }
      button.primary { background:var(--accent); border-color:var(--accent); color:white; }
      .muted { color: var(--muted); }
      .panel {
        position: fixed;
        top:0;
        bottom:0;
        width:min(86vw, 330px);
        background:var(--card);
        border:1px solid var(--border);
        padding:1rem;
        overflow:auto;
        z-index:60;
        box-shadow: var(--shadow);
        transform: translateX(-105%);
        transition: transform .2s ease;
      }
      .panel.right { right:0; left:auto; transform: translateX(105%); }
      .panel.open { transform: translateX(0); }
      .panel h2 { margin:.3rem 0 .8rem; font-size:1rem; }
      .panel a { display:block; padding:.45rem 0; border-bottom:1px dashed var(--border); }
      .backdrop {
        position:fixed;
        inset:0;
        background:rgba(2, 8, 23, .45);
        z-index:55;
        display:none;
      }
      .backdrop.show { display:block; }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="actions">
        <button id="open-main-menu" aria-label="Abrir menú principal">Menu</button>
        <a class="brand" href={base}>Oposición Burgos</a>
      </div>
      <div class="actions">
        <select id="theme-picker" aria-label="Elegir tema visual">
          <option value="system">Sistema</option>
          <option value="light">Claro</option>
          <option value="dark">Oscuro</option>
        </select>
        <button id="open-topics-menu" aria-label="Abrir menú de temas">Temas</button>
      </div>
    </header>

    <aside class="panel" id="main-panel">
      <h2>Estudio</h2>
      <a href={base}>Inicio</a>
      <a href={`${base}test`}>Hacer test</a>
      <a href={`${base}fallos`}>Repetir fallos</a>
      <a href={`${base}progreso`}>Progreso</a>
    </aside>

    <aside class="panel right" id="topics-panel">
      <h2>Temas</h2>
      {temas.map((t) => (
        <a href={`${base}temas/${t.id.replace(/\.md$/, '')}`}>
          Tema {t.data.tema}
        </a>
      ))}
    </aside>
    <div class="backdrop" id="menu-backdrop"></div>

    <main>
      <slot />
    </main>
    <AccessGate />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register(`${base}sw.js`));
      }

      const root = document.documentElement;
      const picker = document.getElementById('theme-picker');
      const saved = localStorage.getItem('oposicion-theme') || 'system';
      picker.value = saved;
      const applyTheme = (mode) => {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
        root.dataset.theme = resolved;
      };
      applyTheme(saved);
      picker?.addEventListener('change', () => {
        localStorage.setItem('oposicion-theme', picker.value);
        applyTheme(picker.value);
      });

      const mainPanel = document.getElementById('main-panel');
      const topicsPanel = document.getElementById('topics-panel');
      const backdrop = document.getElementById('menu-backdrop');
      const closeAll = () => {
        mainPanel?.classList.remove('open');
        topicsPanel?.classList.remove('open');
        backdrop?.classList.remove('show');
      };
      document.getElementById('open-main-menu')?.addEventListener('click', () => {
        mainPanel?.classList.add('open');
        topicsPanel?.classList.remove('open');
        backdrop?.classList.add('show');
      });
      document.getElementById('open-topics-menu')?.addEventListener('click', () => {
        topicsPanel?.classList.add('open');
        mainPanel?.classList.remove('open');
        backdrop?.classList.add('show');
      });
      backdrop?.addEventListener('click', closeAll);
    </script>
  </body>
</html>
