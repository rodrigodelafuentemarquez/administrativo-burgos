---
import { getCollection } from 'astro:content';
type TocItem = {
  depth: number;
  id: string;
  text: string;
};
interface Props {
  title: string;
  toc?: TocItem[];
}
const { title, toc = [] } = Astro.props;
import AccessGate from '../components/AccessGate.astro';
const temas = (await getCollection('temas')).sort((a, b) => a.data.tema - b.data.tema);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<html lang="es" data-bs-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#712cf9" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}icons/icon-192.png`} sizes="192x192" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <title>{title}</title>
    <style is:global>
      :root {
        --bd-purple: #4c0bce;
        --bd-violet: #712cf9;
        --bd-accent: #ffe484;
        --bd-violet-rgb: 113, 44, 249;
        --bd-accent-rgb: 255, 228, 132;
        --bd-violet-bg: var(--bd-violet);
        --bd-toc-color: var(--bd-violet);
        --bd-sidebar-link-bg: rgba(var(--bd-violet-rgb), .1);
      }
      :root[data-bs-theme="dark"] {
        --bd-violet: #9561fb;
        --bd-violet-bg: #712cf9;
        --bd-toc-color: var(--bs-emphasis-color);
        --bd-sidebar-link-bg: rgba(85, 33, 187, .5);
      }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      }
      .btn-primary {
        --bs-btn-bg: var(--bd-violet);
        --bs-btn-border-color: var(--bd-violet);
        --bs-btn-hover-bg: #6528e0;
        --bs-btn-hover-border-color: #6528e0;
        --bs-btn-focus-shadow-rgb: var(--bd-violet-rgb);
      }
      .bd-navbar {
        padding: .75rem 0;
        background-color: transparent;
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15), inset 0 -1px rgba(255,255,255,.15);
      }
      .bd-navbar::after {
        position: absolute;
        inset: 0;
        z-index: -1;
        display: block;
        content: "";
        background-image: linear-gradient(rgba(var(--bd-violet-rgb),1), rgba(var(--bd-violet-rgb),.95));
      }
      .bd-brand {
        color: #fff;
        font-weight: 700;
        text-decoration: none;
        transition: transform .2s ease-in-out;
      }
      .bd-brand:hover {
        color: #fff;
        transform: rotate(-3deg) scale(1.03);
      }
      .bd-brand-mark {
        display: inline-grid;
        width: 2.5rem;
        height: 2rem;
        margin-right: .5rem;
        place-items: center;
        color: var(--bd-violet);
        font-weight: 800;
        background: #fff;
        border-radius: .45rem;
      }
      .bd-navbar .nav-link,
      .bd-navbar .navbar-toggler {
        color: rgba(255,255,255,.85);
      }
      .bd-navbar .nav-link:hover,
      .bd-navbar .navbar-toggler:hover {
        color: #fff;
      }
      .bd-navbar .navbar-toggler {
        border: 0;
      }
      .bd-navbar .navbar-toggler-icon {
        filter: invert(1) grayscale(1) brightness(2);
      }
      .bd-layout {
        display: grid;
        grid-template-areas: "main";
        gap: 1.5rem;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 1.5rem 3rem;
      }
      .bd-sidebar { display: none; }
      .bd-toc { display: none; }
      .bd-main {
        grid-area: main;
        min-width: 0;
        padding-top: 2rem;
      }
      @media (min-width: 992px) {
        .bd-layout {
          grid-template-columns: 1fr 5fr;
          grid-template-areas: "sidebar main";
        }
        .bd-sidebar {
          display: block;
          grid-area: sidebar;
          position: sticky;
          top: 5rem;
          height: calc(100vh - 6rem);
          overflow-y: auto;
          padding: 1.5rem .75rem 2rem 0;
        }
        .bd-main {
          display: grid;
          grid-template-areas:
            "intro toc"
            "content toc";
          grid-template-columns: 4fr 1fr;
          gap: 1.5rem;
        }
        .bd-main:not(.has-toc) {
          grid-template-areas:
            "intro"
            "content";
          grid-template-columns: minmax(0, 1fr);
        }
      }
      @media (min-width: 1200px) {
        .bd-toc {
          display: block;
          grid-area: toc;
          position: sticky;
          top: 5rem;
          right: 0;
          z-index: 2;
          height: calc(100vh - 7rem);
          overflow-y: auto;
          padding: 1.5rem 0 2rem 1rem;
          font-size: .875rem;
        }
      }
      .bd-intro { grid-area: intro; }
      .bd-content {
        grid-area: content;
        min-width: 1px;
      }
      .bd-links-heading {
        color: var(--bs-emphasis-color);
        font-weight: 600;
      }
      .bd-links-link {
        padding: .1875rem .5rem;
        margin-top: .125rem;
        margin-left: 1.125rem;
        color: var(--bs-body-color);
        text-decoration: none;
      }
      .bd-links-link:hover,
      .bd-links-link:focus,
      .bd-links-link.active {
        color: var(--bs-emphasis-color);
        background-color: var(--bd-sidebar-link-bg);
      }
      .bd-links-link.active {
        font-weight: 600;
      }
      .offcanvas .bd-links-nav {
        display: grid;
        gap: .25rem;
      }
      .offcanvas .bd-links-heading {
        margin-bottom: .35rem;
      }
      .offcanvas .bd-links-link {
        display: block !important;
        width: 100%;
        margin-top: 0;
        margin-left: 0;
        padding: .65rem .75rem;
        border: 1px solid transparent;
      }
      .offcanvas .bd-links-link:hover,
      .offcanvas .bd-links-link:focus,
      .offcanvas .bd-links-link.active {
        border-color: var(--bs-border-color);
      }
      .offcanvas .theme-list {
        display: grid;
        gap: .35rem;
      }
      .offcanvas .theme-list .bd-links-link {
        line-height: 1.35;
      }
      .bd-link {
        display: block;
        padding: .1875rem .5rem;
        color: var(--bs-secondary-color);
        text-decoration: none;
      }
      .bd-link:hover {
        color: var(--bs-emphasis-color);
      }
      .bd-toc nav ul {
        padding-left: 0;
        margin-bottom: 0;
        list-style: none;
      }
      .bd-toc nav ul ul {
        padding-left: 1rem;
      }
      .bd-toc nav a {
        display: block;
        padding: .125rem 0 .125rem .75rem;
        color: inherit;
        text-decoration: none;
        border-left: .125rem solid transparent;
      }
      .bd-toc nav a:hover,
      .bd-toc nav a.active {
        color: var(--bd-toc-color);
        border-left-color: var(--bd-toc-color);
      }
      .bd-title {
        color: var(--bs-emphasis-color);
        font-size: calc(1.425rem + 2.1vw);
      }
      @media (min-width: 1200px) {
        .bd-title { font-size: 3rem; }
      }
      .bd-subtitle {
        font-size: 1.25rem;
        font-weight: 300;
        line-height: 1.55;
        color: var(--bs-secondary-color);
      }
      .bd-content > h2,
      .bd-content > h3,
      .bd-content > h4,
      .tema-content > h2,
      .tema-content > h3 {
        color: var(--bs-emphasis-color);
      }
      .tema-content h2,
      .tema-content h3,
      .tema-content h4 {
        scroll-margin-top: 5.5rem;
      }
      .tema-content {
        font-size: 1rem;
      }
      .tema-content h2 {
        margin-top: 3rem;
        margin-bottom: .75rem;
        font-size: calc(1.325rem + .9vw);
        line-height: 1.2;
      }
      .tema-content h3 {
        margin-top: 2rem;
        margin-bottom: .75rem;
        font-size: calc(1.275rem + .3vw);
        line-height: 1.3;
      }
      .tema-content p,
      .tema-content li {
        line-height: 1.7;
      }
      .tema-content table {
        width: 100%;
        max-width: 100%;
        margin-bottom: 1.5rem;
        font-size: .875rem;
        vertical-align: top;
        border-color: var(--bs-border-color);
        display: table;
      }
      @media (max-width: 991.98px) {
        .tema-content table {
          display: block;
          overflow-x: auto;
        }
      }
      .tema-content th,
      .tema-content td {
        padding: .5rem .5rem;
        border: 1px solid var(--bs-border-color);
      }
      .tema-content th {
        color: var(--bs-emphasis-color);
        white-space: nowrap;
        background: transparent;
      }
      .tema-content thead {
        border-bottom: 2px solid currentcolor;
      }
      .tema-content ul { padding-left: 1.25rem; }
      .tema-content > ul li,
      .tema-content > ol li {
        margin-bottom: .25rem;
      }
      .tema-content code {
        color: #d63384;
      }
      .anchor-link {
        padding: 0 .175rem;
        font-weight: 400;
        color: rgba(13,110,253,.5);
        text-decoration: none;
        opacity: 0;
      }
      .anchor-link::after {
        content: "#";
      }
      :hover > .anchor-link,
      .anchor-link:focus,
      .anchor-link:hover {
        color: #0d6efd;
        opacity: 1;
      }
      .bd-callout {
        --bd-callout-link: 10, 88, 202;
        padding: 1.25rem;
        margin-top: 1.25rem;
        margin-bottom: 1.25rem;
        color: var(--bs-body-color);
        background-color: var(--bs-tertiary-bg);
        border-left: .25rem solid var(--bd-violet);
        border-radius: .25rem;
      }
      .syllabus-summary {
        display: grid;
        gap: .75rem;
        margin: 1.25rem 0;
      }
      .syllabus-summary > div {
        display: grid;
        gap: .2rem;
        padding: 1rem;
        background: var(--bs-tertiary-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius);
      }
      .syllabus-summary strong {
        color: var(--bs-emphasis-color);
        font-size: 1.75rem;
        line-height: 1;
      }
      .syllabus-summary span {
        color: var(--bs-secondary-color);
        font-size: .9rem;
      }
      @media (min-width: 768px) {
        .syllabus-summary {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }
      }
      .official-group {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--bs-border-color);
      }
      .official-group-heading {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1rem;
      }
      .official-group-heading h2 {
        margin-bottom: .35rem;
        font-size: 1.5rem;
        line-height: 1.25;
      }
      .official-group-heading p {
        max-width: 48rem;
        margin-bottom: 0;
        color: var(--bs-secondary-color);
      }
      .official-topic-list {
        display: grid;
        gap: .75rem;
      }
      .official-topic {
        padding: 1rem;
        background: var(--bs-tertiary-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius);
      }
      .official-topic-main {
        display: grid;
        gap: .85rem;
      }
      @media (min-width: 768px) {
        .official-topic-main {
          grid-template-columns: 4.25rem minmax(0, 1fr);
        }
      }
      .official-topic-number {
        display: inline-grid;
        width: 3.25rem;
        height: 3.25rem;
        place-items: center;
        color: var(--bd-accent);
        font-weight: 800;
        background: rgba(var(--bd-violet-rgb), .25);
        border: 1px solid rgba(var(--bd-violet-rgb), .4);
        border-radius: var(--bs-border-radius);
      }
      .official-topic-body {
        min-width: 0;
      }
      .official-topic-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: .5rem;
      }
      .official-topic h3 {
        margin-bottom: .75rem;
        color: var(--bs-emphasis-color);
        font-size: 1rem;
        line-height: 1.45;
      }
      .topic-matches {
        display: grid;
        gap: .5rem;
      }
      .topic-matches > span,
      .topic-missing {
        color: var(--bs-secondary-color);
        font-size: .9rem;
      }
      .topic-match-list {
        display: grid;
        gap: .5rem;
      }
      .topic-match {
        display: grid;
        gap: .15rem;
        padding: .75rem;
        color: inherit;
        text-decoration: none;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius-sm);
      }
      .topic-match:hover,
      .topic-match:focus {
        border-color: rgba(var(--bd-violet-rgb), .8);
      }
      .topic-match strong {
        color: var(--bd-accent);
        font-size: .85rem;
      }
      .topic-match span {
        color: var(--bs-emphasis-color);
        font-size: .92rem;
        line-height: 1.35;
      }
      .topic-match small {
        color: var(--bs-secondary-color);
      }
      .study-structure,
      .protection-levels,
      .review-grid {
        margin: 1.25rem 0 1.75rem;
      }
      .study-list {
        margin: 1.25rem 0 1.75rem;
        padding: 1rem 1rem 1rem 1.25rem;
        background: var(--bs-tertiary-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius-lg);
      }
      .study-list ul {
        margin: 0;
        padding-left: 1.1rem;
      }
      .study-list li {
        margin: .5rem 0;
        line-height: 1.6;
      }
      .study-list > ul {
        padding-left: 1rem;
      }
      .study-list > ul > li::marker,
      .study-list-summary > ul > li::marker {
        color: var(--bd-violet);
      }
      .study-list ul ul {
        margin-top: .35rem;
        padding-left: 1.25rem;
        border-left: 1px solid rgba(255, 255, 255, .08);
      }
      .study-list strong {
        color: var(--bs-emphasis-color);
      }
      .study-note {
        color: var(--bs-secondary-color);
        font-size: .95rem;
      }
      .structure-item,
      .protection-levels > section,
      .review-grid > article {
        padding: 1rem;
        background: var(--bs-tertiary-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius);
      }
      .study-structure {
        display: grid;
        gap: .75rem;
      }
      .structure-item {
        display: grid;
        gap: .25rem;
      }
      .structure-item-featured {
        border-left: .25rem solid var(--bd-violet);
      }
      .structure-badge,
      .structure-grid span,
      .protection-levels span {
        display: inline-flex;
        width: fit-content;
        padding: .15rem .45rem;
        color: var(--bd-accent);
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        background: rgba(var(--bd-violet-rgb), .25);
        border-radius: .35rem;
      }
      .structure-item small,
      .structure-grid small,
      .protection-levels p {
        color: var(--bs-secondary-color);
      }
      .structure-item ul,
      .protection-levels ul,
      .review-grid ul {
        margin-bottom: 0;
      }
      .structure-grid {
        display: grid;
        gap: .75rem;
      }
      @media (min-width: 768px) {
        .structure-grid,
        .protection-levels,
        .review-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
      .structure-grid,
      .protection-levels,
      .review-grid {
        display: grid;
      }
      .structure-grid > div {
        display: grid;
        gap: .25rem;
        padding: .85rem;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius);
      }
      .structure-grid strong,
      .review-grid h4,
      .protection-levels h4 {
        color: var(--bs-emphasis-color);
      }
      .protection-levels {
        gap: .75rem;
      }
      .review-grid {
        gap: .75rem;
      }
      .test-shell {
        background: transparent;
      }
      .test-hero,
      .test-panel,
      .question-card,
      .correction-card,
      .result-summary {
        background: var(--bs-tertiary-bg);
      }
      .test-hero {
        padding: 1rem;
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius-lg);
      }
      .test-kicker {
        display: inline-flex;
        width: fit-content;
        padding: .2rem .5rem;
        color: var(--bd-accent);
        font-size: .75rem;
        font-weight: 800;
        letter-spacing: .04em;
        text-transform: uppercase;
        background: rgba(var(--bd-violet-rgb), .25);
        border-radius: .35rem;
      }
      .test-config,
      .test-question-list {
        display: grid;
        gap: 1rem;
      }
      .test-panel {
        padding: 1rem;
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius-lg);
      }
      .test-topic-grid {
        display: grid;
        gap: .65rem;
      }
      .test-topic-option,
      .answer-option {
        display: flex;
        gap: .75rem;
        align-items: flex-start;
        width: 100%;
        padding: .85rem;
        cursor: pointer;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: var(--bs-border-radius);
      }
      .test-topic-option:hover,
      .answer-option:hover {
        border-color: rgba(var(--bd-violet-rgb), .8);
      }
      .test-topic-option small {
        display: block;
        margin-top: .15rem;
        color: var(--bs-secondary-color);
        line-height: 1.35;
      }
      .test-topic-heading {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .5rem;
      }
      .test-topic-count {
        font-size: .72rem;
      }
      .question-number {
        display: inline-grid;
        flex: 0 0 auto;
        width: 2.25rem;
        height: 2.25rem;
        place-items: center;
        color: var(--bd-accent);
        font-weight: 800;
        background: rgba(var(--bd-violet-rgb), .35);
        border-radius: 50%;
      }
      .question-meta {
        color: var(--bs-secondary-color);
        font-size: .875rem;
      }
      .answer-list {
        display: grid;
        gap: .65rem;
      }
      .progress-streak {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        align-items: center;
      }
      .progress-dot {
        display: inline-block;
        width: .85rem;
        height: .85rem;
        border-radius: 999px;
        background: var(--bs-secondary-bg);
        border: 1px solid rgba(255, 255, 255, .08);
      }
      .progress-dot.tone-success { background: var(--bs-success); }
      .progress-dot.tone-primary { background: var(--bd-violet); }
      .progress-dot.tone-warning { background: var(--bs-warning); }
      .progress-dot.tone-danger { background: var(--bs-danger); }
      .answer-option:has(input:checked) {
        color: var(--bs-emphasis-color);
        background: rgba(var(--bd-violet-rgb), .22);
        border-color: var(--bd-violet);
      }
      .test-actions {
        background: linear-gradient(180deg, rgba(33, 37, 41, 0), var(--bs-body-bg) 35%);
      }
      .score-ring {
        display: grid;
        width: 7rem;
        height: 7rem;
        margin-top: 1.5rem;
        place-items: center;
        color: var(--bs-emphasis-color);
        font-size: 1.35rem;
        font-weight: 800;
        background:
          radial-gradient(circle at center, var(--bs-tertiary-bg) 58%, transparent 59%),
          conic-gradient(var(--bd-violet) var(--score), var(--bs-border-color) 0);
        border-radius: 50%;
      }
      .correction-card {
        border-left: .35rem solid var(--bs-border-color) !important;
      }
      .correction-card.is-correct {
        border-left-color: var(--bs-success) !important;
      }
      .correction-card.is-wrong {
        border-left-color: var(--bs-danger) !important;
      }
      #timer-display[data-state="ending"] {
        color: #212529;
        background: #ffc107 !important;
      }
      @media (min-width: 768px) {
        .test-config {
          grid-template-columns: minmax(0, 2fr) minmax(16rem, 1fr);
          align-items: start;
        }
        .score-ring {
          margin-top: 0;
        }
      }
    </style>
  </head>
  <body>
    <header class="navbar navbar-expand-lg bd-navbar sticky-top">
      <nav class="container-xxl flex-wrap flex-lg-nowrap" aria-label="Navegacion principal">
        <div class="d-flex align-items-center">
          <button class="navbar-toggler p-2 d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#menuPrincipal" aria-controls="menuPrincipal" aria-label="Abrir navegacion">
            <span class="navbar-toggler-icon"></span>
          </button>
          <a class="bd-brand d-inline-flex align-items-center p-0 me-lg-3" href={base} aria-label="Oposición Burgos">
            <span class="bd-brand-mark">B</span>
            <span>Oposición Burgos</span>
          </a>
        </div>

        <div class="d-flex align-items-center gap-2 ms-lg-auto">
          <ul class="navbar-nav flex-row flex-wrap d-none d-lg-flex">
            <li class="nav-item"><a class="nav-link py-2 px-2 active" href={base}>Docs</a></li>
            <li class="nav-item"><a class="nav-link py-2 px-2" href={`${base}test`}>Tests</a></li>
            <li class="nav-item"><a class="nav-link py-2 px-2" href={`${base}progreso`}>Progreso</a></li>
          </ul>
          <button class="navbar-toggler p-2 d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#menuTemas" aria-controls="menuTemas" aria-label="Abrir temas">
            Temas
          </button>
        </div>
      </nav>
    </header>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="menuPrincipal" aria-labelledby="menuPrincipalLabel">
      <div class="offcanvas-header">
        <h5 id="menuPrincipalLabel" class="offcanvas-title">Estudio</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
      </div>
      <div class="offcanvas-body">
        <nav class="bd-links-nav">
          <strong class="bd-links-heading d-flex w-100 align-items-center fw-semibold">Estudio</strong>
          <a class="bd-links-link rounded active" href={base}>Inicio</a>
          <a class="bd-links-link rounded" href={`${base}test`}>Hacer test</a>
          <a class="bd-links-link rounded" href={`${base}progreso`}>Progreso</a>
          <a class="bd-links-link rounded" href={`${base}fallos`}>Repetir fallos</a>
        </nav>
      </div>
    </div>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="menuTemas" aria-labelledby="menuTemasLabel">
      <div class="offcanvas-header">
        <h5 id="menuTemasLabel" class="offcanvas-title">Temas</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
      </div>
      <div class="offcanvas-body">
        <nav class="bd-links-nav theme-list" aria-label="Listado de temas">
          {temas.map((t) => (
            <a class="bd-links-link rounded" href={`${base}temas/${t.id.replace(/\.md$/, '')}`}>
              Tema {t.data.tema}: {t.data.titulo}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class={`bd-layout ${toc.length ? 'has-toc' : ''}`}>
      <aside class="bd-sidebar">
        <nav class="bd-links-nav">
          <ul class="list-unstyled mb-0 pb-3 pb-md-2 pe-lg-2">
            <li class="bd-links-group py-2">
              <strong class="bd-links-heading d-flex w-100 align-items-center fw-semibold">Estudio</strong>
              <ul class="list-unstyled fw-normal pb-2 small">
                <li><a class="bd-links-link d-inline-block rounded active" href={base}>Inicio</a></li>
                <li><a class="bd-links-link d-inline-block rounded" href={`${base}test`}>Hacer test</a></li>
                <li><a class="bd-links-link d-inline-block rounded" href={`${base}progreso`}>Progreso</a></li>
                <li><a class="bd-links-link d-inline-block rounded" href={`${base}fallos`}>Repetir fallos</a></li>
              </ul>
            </li>
            <li class="bd-links-group py-2">
              <strong class="bd-links-heading d-flex w-100 align-items-center fw-semibold">Temario</strong>
              <ul class="list-unstyled fw-normal pb-2 small">
                {temas.map((t) => (
                  <li>
                    <a class="bd-links-link d-inline-block rounded" href={`${base}temas/${t.id.replace(/\.md$/, '')}`}>
                      Tema {t.data.tema}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          </ul>
        </nav>
      </aside>

      <main class={`bd-main ${toc.length ? 'has-toc' : ''}`}>
        {toc.length > 0 && (
          <div class="bd-toc mt-3 mb-5 my-lg-0 mb-lg-5 px-sm-1 text-body-secondary">
          <strong class="d-block mb-2">En esta página</strong>
          <nav aria-label="Contenido de esta página">
              <ul>
                {toc.map((item) => (
                  <li class={item.depth > 2 ? 'ms-3' : ''}>
                    <a href={`#${item.id}`}>{item.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        )}
        <slot />
      </main>
    </div>
    <AccessGate />
    <script define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register(`${base}sw.js`));
      }

    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
