---
import { getCollection } from 'astro:content';
interface Props {
  title: string;
}
const { title } = Astro.props;
import AccessGate from '../components/AccessGate.astro';
const temas = (await getCollection('temas')).sort((a, b) => a.data.tema - b.data.tema);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e7490" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}icons/icon-192.png`} sizes="192x192" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <title>{title}</title>
    <script>
      (() => {
        const saved = localStorage.getItem('oposicion-theme') || 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = saved === 'system' ? (prefersDark ? 'dark' : 'light') : saved;
        document.documentElement.setAttribute('data-bs-theme', resolved);
      })();
    </script>
    <style>
      :root { --app-bg: #f5f5f2; }
      :root[data-bs-theme="dark"] { --app-bg: #111111; }
      body {
        font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
        background: var(--app-bg);
      }
      main { max-width: 1000px; margin: 0 auto; padding: 1rem; }
      .card { border-radius: .75rem; padding: 1rem; }
      .muted { color: var(--bs-secondary-color); }
      .grid { display:grid; gap:.75rem; }
      @media (min-width:700px){ .grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
      .navbar-brand { font-weight: 700; }
      .tema-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 1.25rem;
        display: block;
        overflow-x: auto;
        border-radius: .5rem;
        background: var(--bs-body-bg);
      }
      .tema-content th,
      .tema-content td {
        border: 1px solid var(--bs-border-color);
        padding: .6rem .7rem;
        vertical-align: top;
        min-width: 180px;
      }
      .tema-content th {
        background: color-mix(in srgb, var(--bs-body-color) 8%, transparent);
        font-weight: 700;
      }
      .tema-content tr:nth-child(even) td {
        background: color-mix(in srgb, var(--bs-body-color) 3%, transparent);
      }
      .tema-content h2,
      .tema-content h3 { margin-top: 1.45rem; margin-bottom: .65rem; line-height: 1.3; }
      .tema-content h2 { font-size: 1.5rem; }
      .tema-content h3 { font-size: 1.2rem; }
      .tema-content p, .tema-content li { line-height: 1.7; font-size: 1.02rem; }
      .tema-content ul { padding-left: 1.15rem; }
      .tema-content hr { margin: 1.25rem 0; opacity: .18; }
      .tema-content blockquote {
        margin: 1rem 0;
        padding: .7rem .9rem;
        border-left: .25rem solid var(--bs-secondary);
        background: color-mix(in srgb, var(--bs-body-color) 4%, transparent);
        border-radius: .45rem;
      }
      .tema-page {
        max-width: 900px;
        margin: 0 auto;
      }
      .tema-header {
        margin-bottom: 1rem;
      }
      .tema-kicker {
        display: inline-block;
        font-size: .8rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--bs-secondary-color);
        margin-bottom: .35rem;
      }
      .tema-title {
        font-size: clamp(1.45rem, 2.5vw, 2rem);
        line-height: 1.25;
        margin-bottom: 0;
      }
    </style>
  </head>
  <body>
    <header class="sticky-top border-bottom bg-body">
      <div class="container-fluid px-3 py-2 d-flex justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2">
          <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="offcanvas" data-bs-target="#menuPrincipal" aria-controls="menuPrincipal">Menu</button>
          <a class="navbar-brand m-0" href={base}>Oposición Burgos</a>
        </div>
        <div class="d-flex align-items-center gap-2">
          <select id="theme-picker" class="form-select form-select-sm" aria-label="Elegir tema visual">
            <option value="system">Sistema</option>
            <option value="light">Claro</option>
            <option value="dark">Oscuro</option>
          </select>
          <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="offcanvas" data-bs-target="#menuTemas" aria-controls="menuTemas">Temas</button>
        </div>
      </div>
    </header>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="menuPrincipal" aria-labelledby="menuPrincipalLabel">
      <div class="offcanvas-header">
        <h5 id="menuPrincipalLabel" class="offcanvas-title">Estudio</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
      </div>
      <div class="offcanvas-body d-grid gap-2">
        <a class="btn btn-outline-secondary text-start" href={base}>Inicio</a>
        <a class="btn btn-outline-secondary text-start" href={`${base}test`}>Hacer test</a>
        <a class="btn btn-outline-secondary text-start" href={`${base}fallos`}>Repetir fallos</a>
        <a class="btn btn-outline-secondary text-start" href={`${base}progreso`}>Progreso</a>
      </div>
    </div>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="menuTemas" aria-labelledby="menuTemasLabel">
      <div class="offcanvas-header">
        <h5 id="menuTemasLabel" class="offcanvas-title">Temas</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
      </div>
      <div class="offcanvas-body d-grid gap-2">
        {temas.map((t) => (
          <a class="btn btn-outline-secondary text-start" href={`${base}temas/${t.id.replace(/\.md$/, '')}`}>
            Tema {t.data.tema}
          </a>
        ))}
      </div>
    </div>

    <main>
      <slot />
    </main>
    <AccessGate />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register(`${base}sw.js`));
      }

      const root = document.documentElement;
      const picker = document.getElementById('theme-picker');
      const saved = localStorage.getItem('oposicion-theme') || 'system';
      picker.value = saved;
      const applyTheme = (mode) => {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
        root.setAttribute('data-bs-theme', resolved);
      };
      applyTheme(saved);
      picker?.addEventListener('change', () => {
        localStorage.setItem('oposicion-theme', picker.value);
        applyTheme(picker.value);
      });

    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
