---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import GithubSlugger from 'github-slugger';
import NormativeSourceLinks from '../../components/NormativeSourceLinks.astro';
import { getNormativeSources } from '../../data/normativeSources';
import StudyAidBox from '../../components/StudyAidBox.astro';
import { getStudyAid } from '../../data/studyAids';
import TopicReviewBox from '../../components/TopicReviewBox.astro';
import { getTopicReview } from '../../data/topicReview';

export async function getStaticPaths() {
  const temas = await getCollection('programa');
  return temas.map((tema) => ({ params: { slug: tema.id.replace(/\.md$/, '') }, props: { tema } }));
}

const { tema } = Astro.props;
const { Content } = await render(tema);
const slug = tema.id.replace(/\.md$/, '');
const sources = getNormativeSources(slug);
const studyAid = getStudyAid(slug);
const topicReview = getTopicReview(slug);
const slugger = new GithubSlugger();
const toc = tema.body
  .split('\n')
  .map((line) => line.match(/^(#{2,3})\s+(.+)$/))
  .filter(Boolean)
  .map((match) => {
    const text = match![2].replace(/\s*\{#.+\}\s*$/, '').trim();
    return {
      depth: match![1].length,
      text,
      id: slugger.slug(text),
    };
  })
  .slice(0, 12);
---

<Layout title={`${tema.data.codigo} - ${tema.data.titulo}`} toc={toc}>
  <div class="bd-intro ps-lg-2">
    <p class="text-body-secondary fw-semibold mb-2">{tema.data.grupo}</p>
    <h1 class="bd-title">{tema.data.codigo}</h1>
    <p class="bd-subtitle mb-0">{tema.data.titulo}</p>
  </div>
  <div class="bd-content tema-content ps-lg-2">
    <NormativeSourceLinks sources={sources} />
    <StudyAidBox aid={studyAid} />
    <TopicReviewBox review={topicReview} />
    <Content />
  </div>
</Layout>
