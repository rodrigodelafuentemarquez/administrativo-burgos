---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Progreso">
  <h1>Progreso</h1>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
          <h2 class="h4 mb-2">Vista rapida</h2>
          <p class="text-body-secondary mb-0">Nivel actual por tema, historico acumulado y tendencia reciente. Ya no arrastras el progreso antiguo del temario anterior.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <button class="btn btn-outline-secondary btn-sm" id="clear-fails" type="button">Vaciar fallos</button>
          <button class="btn btn-outline-danger btn-sm" id="clear-progress" type="button">Reiniciar progreso</button>
        </div>
      </div>
    </div>
  </div>
  <div id="progress-feedback" class="mb-3"></div>
  <section id="stats" class="test-question-list"></section>

  <script>
    const STATS_KEY = 'oposicion-stats-v3';
    const FAILS_KEY = 'oposicion-fallos-v3';
    const RECENT_WINDOW = 5;
    const ATTEMPT_LIMIT = 12;

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

    const normalizeAttempt = (value) => {
      if (!value || typeof value !== 'object') return null;
      const total = Math.max(0, Number(value.total ?? 0) || 0);
      const correctas = Math.max(0, Number(value.correctas ?? 0) || 0);
      const pct = clamp(Math.round(Number(value.pct ?? 0) || 0), 0, 100);
      const at = Number(value.at ?? 0) || 0;
      if (!at) return null;
      return { total, correctas: Math.min(correctas, total), pct, at };
    };

    const normalizeTemaStats = (value) => {
      const raw = (value && typeof value === 'object') ? value : {};
      const total = Number(raw.total ?? 0);
      const correctas = Number(raw.correctas ?? 0);
      const recent = Array.isArray(raw.recent)
        ? raw.recent
            .map((entry) => Number(entry))
            .filter((entry) => Number.isFinite(entry))
            .slice(-8)
        : [];
      const attempts = Array.isArray(raw.attempts)
        ? raw.attempts
            .map(normalizeAttempt)
            .filter(Boolean)
            .slice(-ATTEMPT_LIMIT)
        : [];
      const updatedAt = Number(raw.updatedAt ?? 0) || null;

      return {
        total: Number.isFinite(total) ? total : 0,
        correctas: Number.isFinite(correctas) ? correctas : 0,
        recent,
        attempts,
        updatedAt,
      };
    };

    const readStats = () => {
      if (typeof localStorage === 'undefined') return {};
      try {
        const raw = JSON.parse(localStorage.getItem(STATS_KEY) ?? '{}');
        if (!raw || typeof raw !== 'object') return {};
        return Object.fromEntries(
          Object.entries(raw).map(([key, value]) => [key, normalizeTemaStats(value)])
        );
      } catch {
        return {};
      }
    };

    const root = document.getElementById('stats');
    const feedback = document.getElementById('progress-feedback');

    const formatDate = (value) => {
      if (!value) return 'Sin fecha';
      try {
        return new Intl.DateTimeFormat('es-ES', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(value));
      } catch {
        return 'Sin fecha';
      }
    };

    const getRecentAttempts = (temaStats) => {
      const attempts = Array.isArray(temaStats.attempts) ? temaStats.attempts.slice(-RECENT_WINDOW) : [];
      if (attempts.length) return attempts;
      const fallbackRecent = Array.isArray(temaStats.recent) ? temaStats.recent.slice(-RECENT_WINDOW) : [];
      return fallbackRecent.map((pct, index) => ({
        total: 0,
        correctas: 0,
        pct,
        at: (temaStats.updatedAt ?? 0) + index,
      }));
    };

    const getCurrentPct = (temaStats) => {
      const attempts = getRecentAttempts(temaStats);
      if (!attempts.length) return 0;
      const weighted = attempts.reduce((acc, attempt, index) => {
        const weight = index + 1;
        return acc + (attempt.pct * weight);
      }, 0);
      const totalWeight = attempts.reduce((acc, _, index) => acc + index + 1, 0);
      return Math.round(weighted / totalWeight);
    };

    const getCurrentQuestions = (temaStats) => {
      return getRecentAttempts(temaStats).reduce((sum, attempt) => {
        const total = Number(attempt.total ?? 0);
        return sum + (total > 0 ? total : 1);
      }, 0);
    };

    const getBand = (pct) => {
      if (pct >= 80) return { label: 'Muy sólido', cls: 'success' };
      if (pct >= 65) return { label: 'Bien encaminado', cls: 'primary' };
      if (pct >= 50) return { label: 'A vigilar', cls: 'warning' };
      return { label: 'Flojo', cls: 'danger' };
    };

    const getTrend = (attempts = []) => {
      const values = attempts.map((attempt) => Number(attempt.pct ?? 0));
      if (values.length < 2) return { label: 'Sin tendencia suficiente', cls: 'secondary' };
      const latestBlock = values.slice(-3);
      const previousBlock = values.slice(-6, -3);
      const latestAvg = Math.round(latestBlock.reduce((sum, value) => sum + value, 0) / latestBlock.length);
      const baseBlock = previousBlock.length ? previousBlock : values.slice(0, -1);
      const baseAvg = baseBlock.length ? Math.round(baseBlock.reduce((sum, value) => sum + value, 0) / baseBlock.length) : latestAvg;
      const delta = latestAvg - baseAvg;
      if (delta >= 8) return { label: `En subida (+${delta})`, cls: 'success' };
      if (delta <= -8) return { label: `Bajando (${delta})`, cls: 'danger' };
      return { label: 'Estable', cls: 'secondary' };
    };

    const flash = (kind, message) => {
      if (!feedback) return;
      feedback.innerHTML = `<div class="alert alert-${kind} border-0 shadow-sm mb-0">${message}</div>`;
      window.setTimeout(() => {
        if (feedback.innerHTML.includes(message)) feedback.innerHTML = '';
      }, 2400);
    };

    const render = () => {
      const stats = readStats();
      const temas = Object.entries(stats).sort((a,b) => Number(a[0]) - Number(b[0]));

      if (!temas.length) {
        root.innerHTML = `
        <article class="card border-0 shadow-sm">
          <div class="card-body p-4">
            <h2 class="h4 mb-2">Aún no hay progreso</h2>
            <p class="text-body-secondary mb-0">Haz uno o varios tests y aquí aparecerán tus temas trabajados, tu nivel actual y el histórico acumulado.</p>
          </div>
        </article>`;
        return;
      }

      const totalCurrentQuestions = temas.reduce((sum, [, v]) => sum + getCurrentQuestions(v), 0);
      const totalCurrentScore = temas.reduce((sum, [, v]) => sum + (getCurrentPct(v) * getCurrentQuestions(v)), 0);
      const totalHistoricalQuestions = temas.reduce((sum, [, v]) => sum + v.total, 0);
      const totalHistoricalCorrect = temas.reduce((sum, [, v]) => sum + v.correctas, 0);
      const totalCurrentPct = totalCurrentQuestions ? Math.round(totalCurrentScore / totalCurrentQuestions) : 0;
      const totalHistoricalPct = totalHistoricalQuestions ? Math.round((totalHistoricalCorrect / totalHistoricalQuestions) * 100) : 0;
      const weakTopics = temas.filter(([, v]) => getCurrentPct(v) < 50).length;

      const summary = `
        <article class='result-summary card border-0 shadow-sm'>
          <div class='card-body p-4 p-lg-5'>
            <span class='test-kicker'>Resumen general</span>
            <div class='d-lg-flex align-items-center justify-content-between gap-4'>
              <div>
                <h2 class='display-6 mb-2'>Nivel actual: ${totalCurrentPct}%</h2>
                <p class='text-body-secondary mb-2'>Calculado con los intentos mas recientes de cada tema.</p>
                <p class='text-body-secondary mb-1'>Historico acumulado: ${totalHistoricalCorrect}/${totalHistoricalQuestions} correctas (${totalHistoricalPct}%).</p>
                <p class='text-body-secondary mb-lg-0'>Temas con actividad: ${temas.length}. Temas flojos ahora mismo: ${weakTopics}.</p>
              </div>
              <div class='score-ring' style='--score:${totalCurrentPct}%'>${totalCurrentPct}%</div>
            </div>
          </div>
        </article>`;

      const cards = temas.map(([tema, v]) => {
        const attempts = getRecentAttempts(v);
        const pct = getCurrentPct(v);
        const historicalPct = v.total ? Math.round((v.correctas / v.total) * 100) : 0;
        const band = getBand(pct);
        const trend = getTrend(attempts);
        const recent = attempts.map((attempt) => attempt.pct).slice(-RECENT_WINDOW);
        const lastUpdated = attempts.length ? attempts[attempts.length - 1].at : v.updatedAt;
        return `
          <article class='card border-0 shadow-sm'>
            <div class='card-body p-4'>
              <div class='d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3'>
                <div>
                  <h2 class='h4 mb-1'>Tema ${tema}</h2>
                  <p class='text-body-secondary mb-0'>Histórico: ${v.correctas}/${v.total} correctas acumuladas (${historicalPct}%)</p>
                </div>
                <span class='badge text-bg-${band.cls}'>${band.label}</span>
              </div>
              <div class='d-flex flex-wrap align-items-center gap-3 mb-3'>
                <strong class='fs-4'>${pct}%</strong>
                <span class='text-body-secondary'>Nivel actual</span>
                <span class='badge text-bg-${trend.cls}'>${trend.label}</span>
              </div>
              <div class='progress-streak mb-2'>
                ${recent.length
                  ? recent.map((value) => `<span class='progress-dot tone-${value >= 80 ? 'success' : value >= 65 ? 'primary' : value >= 50 ? 'warning' : 'danger'}' title='${value}%'></span>`).join('')
                  : `<span class='text-body-secondary small'>Sin historial reciente.</span>`}
              </div>
              <p class='text-body-secondary small mb-1'>Intentos recientes usados para el nivel actual: ${recent.length ? recent.join('% · ') + '%' : 'sin datos'}.</p>
              <p class='text-body-secondary small mb-0'>Última actualización: ${formatDate(lastUpdated)}.</p>
            </div>
          </article>`;
      }).join('');

      root.innerHTML = summary + cards;
    };

    document.getElementById('clear-progress')?.addEventListener('click', () => {
      if (!window.confirm('Se borrara todo el progreso guardado de este temario.')) return;
      localStorage.removeItem(STATS_KEY);
      render();
      flash('warning', 'Progreso reiniciado.');
    });

    document.getElementById('clear-fails')?.addEventListener('click', () => {
      if (!window.confirm('Se borraran todas las preguntas guardadas en fallos.')) return;
      localStorage.removeItem(FAILS_KEY);
      flash('secondary', 'Fallos vaciados.');
    });

    render();
    window.addEventListener('pageshow', render);
    window.addEventListener('storage', (event) => {
      if (event.key === STATS_KEY) render();
    });
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') render();
    });
  </script>
</Layout>
