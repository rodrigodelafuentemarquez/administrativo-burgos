---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { officialTopics } from '../data/burgosSyllabus';

type PlanTask = {
  id: string;
  kind: 'estudio' | 'repaso' | 'test' | 'simulacro' | 'practico' | 'desarrollo' | 'descanso';
  label: string;
  detail: string;
  minutes: number;
  effort: 'minimo' | 'normal' | 'extra';
  href?: string;
};

type PlanDay = {
  date: string;
  phase: string;
  title: string;
  load: string;
  minutes: number;
  focus: string;
  tasks: PlanTask[];
};

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const programa = await getCollection('programa');
const wordCountBySlug = new Map(
  programa.map((entry) => [
    entry.id.replace(/\.md$/, ''),
    entry.body.split(/\s+/).filter(Boolean).length,
  ])
);
const titleBySlug = new Map(programa.map((entry) => [entry.id.replace(/\.md$/, ''), entry.data.titulo]));
const slugOf = (grupo: string, numero: number) => `grupo-${grupo.toLowerCase()}-tema-${String(numero).padStart(2, '0')}`;
const topicUrl = (slug: string) => `${base}programa/${slug}`;
const testUrl = `${base}test`;
const practicalUrl = `${base}practico`;
const developmentUrl = `${base}desarrollo`;

const topics = officialTopics.map((topic) => {
  const slug = slugOf(topic.grupo, topic.numero);
  const words = wordCountBySlug.get(slug) ?? 1100;
  return {
    ...topic,
    slug,
    code: `${topic.grupo}.${topic.numero}`,
    title: titleBySlug.get(slug) ?? topic.titulo,
    words,
  };
});

const groupOrder = ['I', 'II', 'III', 'IV', 'V'];
const orderedTopics = [...topics].sort((a, b) =>
  (groupOrder.indexOf(a.grupo) - groupOrder.indexOf(b.grupo)) || (a.numero - b.numero)
);
const priorityTopics = [...topics].sort((a, b) => {
  const priority = { crítica: 3, alta: 2, normal: 1 };
  return (priority[b.prioridad] - priority[a.prioridad]) || (b.words - a.words);
});
const criticalTopics = priorityTopics.filter((topic) => topic.prioridad === 'crítica');
const practicalTopics = orderedTopics.filter((topic) => ['III', 'IV', 'V'].includes(topic.grupo));

const start = new Date('2026-07-18T12:00:00');
const end = new Date('2027-05-31T12:00:00');
const phaseOf = (date: Date) => {
  if (date < new Date('2026-09-14T00:00:00')) return 'Vuelta 1';
  if (date < new Date('2026-11-01T00:00:00')) return 'Consolidación';
  if (date < new Date('2027-03-01T00:00:00')) return 'Ventana 1º ejercicio';
  if (date < new Date('2027-04-15T00:00:00')) return 'Preparación 2º ejercicio';
  return 'Preparación 3º ejercicio';
};
const isVacation = (dateKey: string) => dateKey >= '2026-08-19' && dateKey <= '2026-08-30';
const iso = (date: Date) => date.toISOString().slice(0, 10);
const addDays = (date: Date, days: number) => {
  const next = new Date(date);
  next.setDate(next.getDate() + days);
  return next;
};
let studyCursor = 9;
let reviewCursor = 0;
let criticalCursor = 0;
let practicalCursor = 0;
let dayNumber = 0;
const introducedTopics: typeof orderedTopics = orderedTopics.slice(0, studyCursor);
const topicReadCounts = new Map<string, number>(introducedTopics.map((topic) => [topic.code, 1]));

const pickFromIntroduced = (offset = 0) => {
  const pool = introducedTopics.length ? introducedTopics : [orderedTopics[0]];
  return pool[(reviewCursor + offset) % pool.length];
};
const introduceTopicTask = (dateKey: string, minutes: number, effort: PlanTask['effort'] = 'minimo'): PlanTask => {
  const topic = orderedTopics[studyCursor % orderedTopics.length];
  const count = (topicReadCounts.get(topic.code) ?? 0) + 1;
  topicReadCounts.set(topic.code, count);
  studyCursor += 1;
  if (!introducedTopics.some((seen) => seen.code === topic.code)) introducedTopics.push(topic);
  const labelPrefix = count === 1 ? 'Leer' : `${count}ª lectura`;
  return {
    id: `${dateKey}-study-${studyCursor}`,
    kind: 'estudio',
    label: `${labelPrefix} Tema ${topic.code}`,
    detail: `${topic.title}. Lectura activa: estructura, artículos/plazos y 5 ideas que puedan caer en test.`,
    minutes,
    effort,
    href: topicUrl(topic.slug),
  };
};
const rereadRecentTask = (dateKey: string, minutes: number, effort: PlanTask['effort'] = 'normal'): PlanTask => {
  const index = ((studyCursor - 1 - (reviewCursor % 2)) % orderedTopics.length + orderedTopics.length) % orderedTopics.length;
  const topic = orderedTopics[index] ?? orderedTopics[0];
  reviewCursor += 1;
  return {
    id: `${dateKey}-reread-${reviewCursor}`,
    kind: 'estudio',
    label: `Releer Tema ${topic.code}`,
    detail: `${topic.title}. Segunda lectura rápida: índice, epígrafes, artículos y errores de test.`,
    minutes,
    effort,
    href: topicUrl(topic.slug),
  };
};
const reviewTask = (dateKey: string, minutes: number, scope = 'repaso', effort: PlanTask['effort'] = 'normal'): PlanTask => {
  const topic = pickFromIntroduced();
  reviewCursor += 1;
  return {
    id: `${dateKey}-review-${reviewCursor}`,
    kind: 'repaso',
    label: `${scope}: Tema ${topic.code}`,
    detail: `${topic.title}. Relee solo esquema, marcas y fallos; no vuelvas a estudiar todo el tema.`,
    minutes,
    effort,
    href: topicUrl(topic.slug),
  };
};
const testTask = (dateKey: string, minutes: number, label = '3 tests de 15 preguntas', effort: PlanTask['effort'] = 'normal'): PlanTask => {
  const t1 = pickFromIntroduced(0);
  const t2 = pickFromIntroduced(1);
  const t3 = pickFromIntroduced(2);
  return {
    id: `${dateKey}-test-${dayNumber}`,
    kind: 'test',
    label,
    detail: `Solo con temas ya vistos: ${t1.code}, ${t2.code} y ${t3.code}. Corrige al momento y guarda fallos/dudosas.`,
    minutes,
    effort,
    href: testUrl,
  };
};
const practicalTask = (dateKey: string, minutes: number, effort: PlanTask['effort'] = 'minimo'): PlanTask => {
  const topic = practicalTopics[practicalCursor % practicalTopics.length];
  practicalCursor += 1;
  return {
    id: `${dateKey}-practical-${practicalCursor}`,
    kind: 'practico',
    label: `Supuesto práctico sobre Tema ${topic.code}`,
    detail: `${topic.title}. Resuelve con estructura: hechos, norma aplicable, trámites, órgano competente y conclusión.`,
    minutes,
    effort,
    href: practicalUrl,
  };
};
const developmentTask = (dateKey: string, minutes: number, effort: PlanTask['effort'] = 'minimo'): PlanTask => {
  const pool = criticalTopics.length ? criticalTopics : priorityTopics;
  const topic = pool[criticalCursor % pool.length];
  criticalCursor += 1;
  return {
    id: `${dateKey}-development-${criticalCursor}`,
    kind: 'desarrollo',
    label: `Desarrollo escrito Tema ${topic.code}`,
    detail: `${topic.title}. Memoriza índice, redacta introducción y canta el orden completo sin mirar.`,
    minutes,
    effort,
    href: developmentUrl,
  };
};

const buildDay = (date: Date): PlanDay => {
  dayNumber += 1;
  const dateKey = iso(date);
  const dow = date.getDay();
  const isSaturday = dow === 6;
  const isSunday = dow === 0;
  const phase = isVacation(dateKey) ? 'Vacaciones' : phaseOf(date);
  const tasks: PlanTask[] = [];
  let title = '';
  let focus = '';

  if (isVacation(dateKey)) {
    title = 'Vacaciones: mantenimiento';
    focus = 'Sin temario nuevo. Poco repaso y tests diarios para no perder ritmo.';
    tasks.push(testTask(dateKey, 30, '2 tests de 15 preguntas', 'minimo'), reviewTask(dateKey, 25, 'Repaso ligero', 'normal'));
  } else if (phase === 'Vuelta 1') {
    title = 'Temario seguido + test';
    focus = 'Continuar desde el Grupo II sin arrastrar días pasados; si vas fuerte, adelanta la siguiente tarea futura en modo extra.';
    if (isSaturday) {
      tasks.push(introduceTopicTask(dateKey, 60), introduceTopicTask(dateKey, 50, 'normal'), rereadRecentTask(dateKey, 30, 'normal'), testTask(dateKey, 60, '4 tests de 15 preguntas', 'normal'));
    } else if (isSunday) {
      tasks.push(testTask(dateKey, 60, '4 tests de 15 preguntas', 'minimo'), reviewTask(dateKey, 40, 'Repaso de fallos', 'normal'), reviewTask(dateKey, 35, 'Segunda vuelta rápida', 'normal'));
    } else {
      tasks.push(introduceTopicTask(dateKey, 60), testTask(dateKey, 45, '3 tests de 15 preguntas', 'normal'), reviewTask(dateKey, 25, 'Repaso breve', 'normal'));
    }
  } else if (phase === 'Consolidación') {
    title = 'Relectura + test fuerte';
    focus = 'Segundas lecturas en orden, muchos tests y corrección de fallos.';
    if (isSaturday) {
      tasks.push(testTask(dateKey, 90, 'Simulacro de 70 preguntas', 'minimo'), reviewTask(dateKey, 60, 'Corrección', 'normal'), introduceTopicTask(dateKey, 45, 'normal'));
    } else if (isSunday) {
      tasks.push(testTask(dateKey, 75, '5 tests de 15 preguntas', 'minimo'), reviewTask(dateKey, 55, 'Fallos de la semana', 'normal'));
    } else {
      tasks.push(introduceTopicTask(dateKey, 45), testTask(dateKey, 60, '4 tests de 15 preguntas', 'normal'), reviewTask(dateKey, 35, 'Fallos', 'normal'));
    }
  } else if (phase === 'Ventana 1º ejercicio') {
    title = 'Modo test';
    focus = 'Primer ejercicio: simulacro, velocidad y fallos.';
    if (isSaturday) {
      tasks.push(testTask(dateKey, 100, 'Simulacro oficial de 70 preguntas', 'minimo'), reviewTask(dateKey, 80, 'Corrección profunda', 'normal'), testTask(dateKey, 45, '3 tests de 15 preguntas', 'normal'));
    } else if (isSunday) {
      tasks.push(testTask(dateKey, 90, '6 tests de 15 preguntas', 'minimo'), reviewTask(dateKey, 60, 'Fallos y dudosas', 'normal'));
    } else {
      tasks.push(testTask(dateKey, 75, '5 tests de 15 preguntas', 'minimo'), reviewTask(dateKey, 45, 'Fallos y dudosas', 'normal'), introduceTopicTask(dateKey, 45, 'normal'));
    }
  } else if (phase === 'Preparación 2º ejercicio') {
    title = 'Supuesto práctico con mantenimiento de test';
    focus = 'Entrenar casos de grupos III, IV y V y conservar el nivel de preguntas tipo test.';
    if (isSaturday) {
      tasks.push(practicalTask(dateKey, 130), reviewTask(dateKey, 80, 'normativa aplicable', 'normal'), testTask(dateKey, 45, 'Test mantenimiento 40 preguntas', 'normal'), developmentTask(dateKey, 45, 'normal'));
    } else if (isSunday) {
      tasks.push(practicalTask(dateKey, 110), developmentTask(dateKey, 80, 'normal'), reviewTask(dateKey, 50, 'fallos prácticos', 'normal'));
    } else {
      tasks.push(practicalTask(dateKey, 75), reviewTask(dateKey, 55, 'norma y plazos', 'normal'), testTask(dateKey, 30, 'Test mantenimiento 25 preguntas', 'normal'), developmentTask(dateKey, 20, 'normal'));
    }
  } else {
    title = 'Desarrollo final y defensa de estructura';
    focus = 'Memorizar índices, redactar temas completos y mantener una mínima agilidad de test.';
    if (isSaturday) {
      tasks.push(developmentTask(dateKey, 140), reviewTask(dateKey, 70, 'comparativa de temas', 'normal'), testTask(dateKey, 40, 'Test mantenimiento 35 preguntas', 'normal'), practicalTask(dateKey, 50, 'normal'));
    } else if (isSunday) {
      tasks.push(developmentTask(dateKey, 120), reviewTask(dateKey, 70, 'canto de índices', 'normal'), practicalTask(dateKey, 50, 'normal'));
    } else {
      tasks.push(developmentTask(dateKey, 80), reviewTask(dateKey, 55, 'artículos y plazos', 'normal'), testTask(dateKey, 25, 'Test mantenimiento 20 preguntas', 'normal'), practicalTask(dateKey, 20, 'normal'));
    }
  }

  const minutes = tasks.reduce((sum, task) => sum + task.minutes, 0);
  const load = minutes >= 60 ? `${Math.floor(minutes / 60)} h${minutes % 60 ? ` ${minutes % 60} min` : ''}` : `${minutes} min`;
  if (!tasks.length) {
    tasks.push({
      id: `${dateKey}-rest`,
      kind: 'descanso',
      label: 'Descanso activo',
      detail: 'Solo lectura ligera o recuperación si vas muy justo.',
      minutes: 30,
      effort: 'minimo',
    });
  }

  return { date: dateKey, phase, title, load, minutes, focus, tasks };
};

const planDays: PlanDay[] = [];
for (let date = start; date <= end; date = addDays(date, 1)) {
  planDays.push(buildDay(date));
}

const planJson = JSON.stringify(planDays);
---

<Layout title="Planning de estudio">
  <div class="bd-intro ps-lg-2 planning-intro">
    <span class="test-kicker">Planning adaptativo</span>
    <h1 class="planning-title mb-2">Planning de estudio</h1>
    <p class="planning-subtitle mb-0">Calendario diario desde julio de 2026, con arrastre automático de pendientes.</p>
  </div>

  <section class="bd-content ps-lg-2 planning-page">
    <section class="planning-board" aria-label="Calendario de estudio">
      <div class="planning-calendar-card">
        <div class="planning-toolbar">
          <div>
            <span class="test-kicker" id="month-phase">Planning</span>
            <h2 id="month-title">Calendario</h2>
          </div>
          <div class="planning-actions">
            <button class="btn btn-outline-secondary btn-sm" id="prev-month" type="button" aria-label="Mes anterior">‹</button>
            <button class="btn btn-outline-secondary btn-sm" id="jump-today" type="button">Hoy</button>
            <button class="btn btn-outline-secondary btn-sm" id="next-month" type="button" aria-label="Mes siguiente">›</button>
          </div>
        </div>
        <div class="planning-weekdays" aria-hidden="true">
          <span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span>D</span>
        </div>
        <div id="planning-calendar" class="planning-calendar"></div>
      </div>

      <aside class="planning-detail" aria-live="polite">
        <div id="day-detail"></div>
      </aside>
    </section>
  </section>

  <script define:vars={{ planJson }}>
    const PLAN = JSON.parse(planJson);
    const DONE_KEY = 'oposicion-planning-done-v1';
    const MODE_KEY = 'oposicion-planning-mode-v1';
    const calendarRoot = document.getElementById('planning-calendar');
    const dayDetail = document.getElementById('day-detail');
    const monthTitle = document.getElementById('month-title');
    const monthPhase = document.getElementById('month-phase');
    const dayFmt = new Intl.DateTimeFormat('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
    const monthFmt = new Intl.DateTimeFormat('es-ES', { month: 'long', year: 'numeric' });
    const toLocalIso = (date) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    };
    const todayIso = toLocalIso(new Date());
    const firstPlanDate = new Date(`${PLAN[0].date}T12:00:00`);
    const todayInPlan = PLAN.some((day) => day.date === todayIso);
    let visibleMonth = todayInPlan ? new Date() : firstPlanDate;
    visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth(), 1, 12);
    let selectedDate = todayInPlan ? todayIso : PLAN[0].date;
    const dayByDate = new Map(PLAN.map((day) => [day.date, day]));
    const modeLabel = {
      minimo: 'Mínimo',
      normal: 'Normal',
      extra: 'Extra',
    };
    const coreKinds = new Set(['estudio', 'practico', 'desarrollo']);

    const readDone = () => {
      try {
        const raw = JSON.parse(localStorage.getItem(DONE_KEY) ?? '{}');
        return raw && typeof raw === 'object' ? raw : {};
      } catch {
        return {};
      }
    };
    const writeDone = (done) => localStorage.setItem(DONE_KEY, JSON.stringify(done));
    const readModes = () => {
      try {
        const raw = JSON.parse(localStorage.getItem(MODE_KEY) ?? '{}');
        return raw && typeof raw === 'object' ? raw : {};
      } catch {
        return {};
      }
    };
    const writeModes = (modes) => localStorage.setItem(MODE_KEY, JSON.stringify(modes));
    const modeForDate = (date) => readModes()[date] ?? 'normal';
    const isDone = (done, id) => Boolean(done[id]);
    const taskClass = (kind) => `planning-task planning-task--${kind}`;
    const kindLabel = {
      estudio: 'Estudio',
      repaso: 'Repaso',
      test: 'Test',
      simulacro: 'Simulacro',
      practico: 'Práctico',
      desarrollo: 'Desarrollo',
      descanso: 'Descanso',
    };
    const escapeHtml = (value) => String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');
    const shortTask = (task) => {
      const topic = task.label.match(/Tema [IVX]+\.\d+(?: bloque \d+\/\d+)?/);
      if (topic) return topic[0].replace('Tema ', '');
      if (task.label.includes('Simulacro')) return 'Simulacro';
      if (task.label.includes('tests') || task.label.includes('Test')) return 'Tests';
      if (task.kind === 'repaso') return 'Repaso';
      return kindLabel[task.kind] ?? task.kind;
    };
    const splitCalendarLabel = (task) => {
      const raw = shortTask(task);
      const topic = raw.match(/^([IVX]+\.\d+)(?: bloque (\d+\/\d+))?/);
      const compactKind = {
        estudio: 'Est.',
        repaso: 'Rep.',
        test: 'Test',
        simulacro: 'Sim.',
        practico: 'Prác.',
        desarrollo: 'Des.',
        descanso: 'Libre',
      };
      if (topic) return { main: topic[1], sub: topic[2] ?? compactKind[task.kind] ?? kindLabel[task.kind] };
      return { main: raw, sub: `${task.minutes} min` };
    };
    const monthKey = (date) => `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
    const loadLabel = (minutes) => minutes >= 60 ? `${Math.floor(minutes / 60)} h${minutes % 60 ? ` ${minutes % 60} min` : ''}` : `${minutes} min`;
    const baseTasksForMode = (day, mode) => day.tasks.filter((task) => {
      if (mode === 'minimo') return task.effort === 'minimo';
      if (mode === 'extra') return task.effort !== 'extra';
      return task.effort !== 'extra';
    });
    const isCoreTask = (task) => coreKinds.has(task.kind);
    const isCompletedOnDate = (done, taskId, dateKey) => {
      const completedAt = Number(done[taskId] ?? 0);
      return completedAt > 0 && toLocalIso(new Date(completedAt)) === dateKey;
    };
    const plannedCoreTasksUntil = (dateKey, includeFuture = false) => PLAN
      .filter((planDay) => includeFuture || planDay.date <= dateKey)
      .flatMap((planDay) => planDay.tasks
        .filter(isCoreTask)
        .map((task) => ({ ...task, plannedDate: planDay.date })));
    const decorateCoreTask = (task, currentDate) => {
      if (task.plannedDate < currentDate) {
        return {
          ...task,
          label: `Pendiente: ${task.label}`,
          detail: `${task.detail} Tarea arrastrada desde ${dayFmt.format(new Date(`${task.plannedDate}T12:00:00`))}.`,
        };
      }
      if (task.plannedDate > currentDate) {
        return {
          ...task,
          label: `Adelantar: ${task.label}`,
          detail: `${task.detail} Tarea prevista para ${dayFmt.format(new Date(`${task.plannedDate}T12:00:00`))}.`,
          advanceFrom: task.plannedDate,
        };
      }
      return task;
    };
    const visibleTasksForMode = (day, done, mode) => {
      const baseTasks = baseTasksForMode(day, mode);
      const coreSlots = baseTasks.filter(isCoreTask).length + (mode === 'extra' ? 1 : 0);
      const coreQueue = plannedCoreTasksUntil(day.date, mode === 'extra')
        .filter((task) => !isDone(done, task.id) || isCompletedOnDate(done, task.id, day.date))
        .slice(0, coreSlots)
        .map((task) => decorateCoreTask(task, day.date));

      if (!coreSlots) return baseTasks;

      const adjustedTasks = [];
      baseTasks.forEach((task) => {
        if (!isCoreTask(task)) {
          adjustedTasks.push(task);
          return;
        }
        const nextCoreTask = coreQueue.shift();
        if (nextCoreTask) adjustedTasks.push(nextCoreTask);
      });
      adjustedTasks.push(...coreQueue);
      return adjustedTasks;
    };

    const taskTemplate = (task, done, carried = false) => `
      <div class="${taskClass(task.kind)} ${isDone(done, task.id) ? 'is-done' : ''}">
        <label class="planning-task-check">
          <input type="checkbox" data-task-id="${task.id}" ${isDone(done, task.id) ? 'checked' : ''} />
          <span>
            <strong>${escapeHtml(task.label)}</strong>
            <small>${carried ? 'Arrastrado · ' : ''}${task.advanceFrom ? `Previsto ${task.advanceFrom} · ` : ''}${task.minutes} min</small>
          </span>
        </label>
        <details>
          <summary>Detalle</summary>
          <p>${escapeHtml(task.detail)}</p>
          ${task.href ? `<a href="${task.href}">Abrir</a>` : ''}
        </details>
      </div>`;

    const getCarriedTasks = (done) => {
      const modes = readModes();
      return PLAN
        .filter((day) => day.date < todayIso)
        .flatMap((day) => baseTasksForMode(day, modes[day.date] ?? 'normal').map((task) => ({ ...task, sourceDate: day.date })))
        .filter((task) => !isDone(done, task.id));
    };

    const renderDetail = (done) => {
      const day = dayByDate.get(selectedDate) ?? PLAN[0];
      const mode = modeForDate(day.date);
      const visibleTasks = visibleTasksForMode(day, done, mode);
      const visibleTaskIds = new Set(visibleTasks.map((task) => task.id));
      const carried = getCarriedTasks(done).filter((task) => !visibleTaskIds.has(task.id));
      const completed = visibleTasks.filter((task) => isDone(done, task.id)).length;
      const visibleMinutes = visibleTasks.reduce((sum, task) => sum + task.minutes, 0);
      const carriedHtml = selectedDate === todayIso
        ? (carried.length
          ? `<section class="planning-carried"><h3>Arrastre (${carried.length})</h3>${carried.slice(0, 6).map((task) => taskTemplate(task, done, true)).join('')}${carried.length > 6 ? `<p class="text-body-secondary small mb-0">+${carried.length - 6} pendientes anteriores.</p>` : ''}</section>`
          : `<section class="planning-carried is-clear"><h3>Sin arrastres</h3><p class="mb-0 text-body-secondary">Nada pendiente de días anteriores.</p></section>`)
        : '';
      dayDetail.innerHTML = `
        <article class="planning-day ${day.date === todayIso ? 'planning-day--today' : ''}" id="today">
          <div class="planning-day-head">
            <div>
              <span class="test-kicker">${escapeHtml(day.phase)}</span>
              <h2>${dayFmt.format(new Date(`${day.date}T12:00:00`))}</h2>
              <p>${escapeHtml(day.title)}</p>
            </div>
            <fieldset class="planning-mode" aria-label="Carga de estudio del día">
              ${['minimo', 'normal', 'extra'].map((option) => `
                <label class="${mode === option ? 'is-active' : ''}">
                  <input type="radio" name="planning-mode-${day.date}" value="${option}" data-mode-date="${day.date}" ${mode === option ? 'checked' : ''} />
                  <span>${modeLabel[option]}</span>
                </label>
              `).join('')}
            </fieldset>
            <div class="planning-load">
              <strong>${loadLabel(visibleMinutes)}</strong>
              <small>${completed}/${visibleTasks.length} · ${modeLabel[mode]}</small>
            </div>
          </div>
          <p class="planning-focus">${escapeHtml(day.focus)}</p>
          <div class="planning-task-list">${visibleTasks.map((task) => taskTemplate(task, done)).join('')}</div>
        </article>
        ${carriedHtml}`;
    };

    const renderCalendar = (preserveDetail = false) => {
      const done = readDone();
      const year = visibleMonth.getFullYear();
      const month = visibleMonth.getMonth();
      const first = new Date(year, month, 1, 12);
      const last = new Date(year, month + 1, 0, 12);
      const leading = (first.getDay() + 6) % 7;
      const monthDays = [];
      for (let i = 0; i < leading; i += 1) monthDays.push(null);
      for (let day = 1; day <= last.getDate(); day += 1) monthDays.push(new Date(year, month, day, 12));
      while (monthDays.length % 7) monthDays.push(null);
      const visibleDays = monthDays
        .filter(Boolean)
        .map((date) => dayByDate.get(toLocalIso(date)))
        .filter(Boolean);
      const phases = [...new Set(visibleDays.map((day) => day.phase))];
      monthTitle.textContent = monthFmt.format(visibleMonth).replace(/^\w/, (letter) => letter.toUpperCase());
      monthPhase.textContent = phases.length === 1 ? phases[0] : 'Calendario';
      if (!preserveDetail) {
        const currentMonthSelected = selectedDate.startsWith(monthKey(visibleMonth));
        selectedDate = currentMonthSelected ? selectedDate : (visibleDays[0]?.date ?? PLAN[0].date);
      }
      calendarRoot.innerHTML = monthDays.map((date) => {
        if (!date) return `<div class="calendar-day calendar-day--empty"></div>`;
        const dateKey = toLocalIso(date);
        const day = dayByDate.get(dateKey);
        if (!day) return `<div class="calendar-day calendar-day--outside"><span>${date.getDate()}</span></div>`;
        const mode = modeForDate(day.date);
        const visibleTasks = visibleTasksForMode(day, done, mode);
        const completed = visibleTasks.filter((task) => isDone(done, task.id)).length;
        const mainStudy = visibleTasks.find((task) => task.kind === 'estudio')
          ?? visibleTasks.find((task) => task.kind === 'practico')
          ?? visibleTasks.find((task) => task.kind === 'desarrollo')
          ?? visibleTasks[0];
        const kinds = [...new Set(visibleTasks.map((task) => task.kind))].slice(0, 4);
        const label = splitCalendarLabel(mainStudy);
        const pct = visibleTasks.length ? Math.round((completed / visibleTasks.length) * 100) : 0;
        return `
          <button class="calendar-day ${day.date === selectedDate ? 'is-selected' : ''} ${day.date === todayIso ? 'is-today' : ''}" type="button" data-date="${day.date}">
            <span class="calendar-day__number">${date.getDate()}</span>
            <strong>${escapeHtml(label.main)}</strong>
            <small>${escapeHtml(label.sub)}</small>
            <div class="calendar-day__chips">
              ${kinds.map((kind) => `<span class="chip chip--${kind}" title="${escapeHtml(kindLabel[kind] ?? kind)}" aria-label="${escapeHtml(kindLabel[kind] ?? kind)}"></span>`).join('')}
            </div>
            <span class="calendar-day__bar"><i style="width:${pct}%"></i></span>
          </button>`;
      }).join('');
      renderDetail(done);
    };

    document.addEventListener('change', (event) => {
      const input = event.target;
      if (!(input instanceof HTMLInputElement) || !input.dataset.taskId) return;
      const done = readDone();
      if (input.checked) done[input.dataset.taskId] = Date.now();
      else delete done[input.dataset.taskId];
      writeDone(done);
      renderCalendar(true);
    });
    document.addEventListener('change', (event) => {
      const input = event.target;
      if (!(input instanceof HTMLInputElement) || !input.dataset.modeDate) return;
      const modes = readModes();
      modes[input.dataset.modeDate] = input.value;
      writeModes(modes);
      renderCalendar(true);
    });

    calendarRoot.addEventListener('click', (event) => {
      const button = event.target.closest('[data-date]');
      if (!button) return;
      selectedDate = button.dataset.date;
      renderCalendar(true);
    });
    document.getElementById('jump-today')?.addEventListener('click', () => {
      selectedDate = todayInPlan ? todayIso : PLAN[0].date;
      const target = new Date(`${selectedDate}T12:00:00`);
      visibleMonth = new Date(target.getFullYear(), target.getMonth(), 1, 12);
      renderCalendar(true);
    });
    document.getElementById('prev-month')?.addEventListener('click', () => {
      visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() - 1, 1, 12);
      renderCalendar();
    });
    document.getElementById('next-month')?.addEventListener('click', () => {
      visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() + 1, 1, 12);
      renderCalendar();
    });
    window.addEventListener('study-sync-applied', () => renderCalendar(true));
    renderCalendar();
  </script>

