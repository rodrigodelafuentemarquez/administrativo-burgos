    .planning-task details {
      margin-left: 1.55rem;
      color: var(--bs-secondary-color);
      font-size: .9rem;
    }
    .planning-task summary {
      width: fit-content;
      cursor: pointer;
      color: var(--bd-accent);
      font-size: .82rem;
      font-weight: 700;
    }
    .planning-task details p {
      margin: .4rem 0 0;
      line-height: 1.45;
    }
    .planning-task a {
