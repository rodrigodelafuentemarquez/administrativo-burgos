---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import TemaCard from '../components/TemaCard.astro';

const temas = (await getCollection('temas')).sort((a, b) => a.data.tema - b.data.tema);
---

<Layout title="Oposición Administrativo - Diputación de Burgos">
  <h1 style="margin:.2rem 0 .6rem">Temario</h1>
  <p class="muted">Selecciona un tema para estudiar.</p>
  <section class="grid">
    {temas.map((t) => <TemaCard tema={t.data.tema} titulo={t.data.titulo} slug={t.id.replace(/\.md$/, '')} />)}
  </section>
</Layout>
