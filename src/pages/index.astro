---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { officialGroups } from '../data/burgosSyllabus';

const officialContent = await getCollection('programa');
const officialContentIds = new Set(officialContent.map((tema) => tema.id.replace(/\.md$/, '')));
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const priorityLabel = {
  normal: 'Test y desarrollo',
  alta: 'Alta prioridad',
  crítica: 'Practico + desarrollo',
};
const officialSlug = (grupo: string, numero: number) => `grupo-${grupo.toLowerCase()}-tema-${String(numero).padStart(2, '0')}`;
---

<Layout title="Administrativo Burgos 2026">
  <div class="bd-intro ps-lg-2">
    <h1 class="bd-title">Administrativo Burgos</h1>
    <p class="bd-subtitle mb-0">Temario oficial completo de la convocatoria, organizado por grupos y temas.</p>
  </div>
  <section class="bd-content ps-lg-2">
    <section class="official-group" id="seguimiento">
      <div class="official-group-heading">
        <div>
          <h2>Seguimiento oficial<a class="anchor-link" aria-label="Enlace a esta sección" href="#seguimiento"></a></h2>
          <p>Hemos dejado también una guía rápida para saber dónde salen novedades, fechas, listas y anuncios del proceso.</p>
        </div>
      </div>
      <div class="official-topic-list">
        <article class="official-topic">
          <div class="official-topic-main">
            <div class="official-topic-number">!</div>
            <div class="official-topic-body">
              <div class="official-topic-meta">
                <span class="badge text-bg-dark">Ayuntamiento + BOP + BOE</span>
              </div>
              <h3>Cómo seguir la convocatoria</h3>
              <p>Enlaces oficiales, rutina de revisión y alertas recomendadas para no perder ninguna novedad.</p>
              <a class="btn btn-sm btn-primary" href={`${base}convocatoria`}>Abrir seguimiento</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="official-group" id="por-ejercicio">
      <div class="official-group-heading">
        <div>
          <h2>Preparación por ejercicio<a class="anchor-link" aria-label="Enlace a esta sección" href="#por-ejercicio"></a></h2>
          <p>La web ya esta separada por lo que de verdad necesitas entrenar: test, supuesto práctico y desarrollo de temas.</p>
        </div>
      </div>
      <div class="official-topic-list">
        <article class="official-topic">
          <div class="official-topic-main">
            <div class="official-topic-number">1º</div>
            <div class="official-topic-body">
              <div class="official-topic-meta">
                <span class="badge text-bg-success">70 preguntas</span>
                <span class="badge text-bg-dark">Penalización real</span>
              </div>
              <h3>Primer ejercicio</h3>
              <p>Tests por tema, por mezcla, simulacro oficial y repaso inteligente.</p>
              <a class="btn btn-sm btn-primary" href={`${base}test`}>Ir a tests</a>
            </div>
          </div>
        </article>
        <article class="official-topic">
          <div class="official-topic-main">
            <div class="official-topic-number">R</div>
            <div class="official-topic-body">
              <div class="official-topic-meta">
                <span class="badge text-bg-warning text-dark">Depuración</span>
                <span class="badge text-bg-dark">Dudosas</span>
              </div>
              <h3>Revisión de preguntas</h3>
              <p>Marca preguntas dudosas al corregir y revísalas luego en un bloque separado para afinar el banco.</p>
              <a class="btn btn-sm btn-primary" href={`${base}dudosas`}>Ir a dudosas</a>
            </div>
          </div>
        </article>
        <article class="official-topic">
          <div class="official-topic-main">
            <div class="official-topic-number">2º</div>
            <div class="official-topic-body">
              <div class="official-topic-meta">
                <span class="badge text-bg-primary">Grupos III, IV y V</span>
                <span class="badge text-bg-dark">Supuestos</span>
              </div>
              <h3>Segundo ejercicio</h3>
              <p>Checklist, textos legales y supuestos modelo inspirados en ejercicios reales.</p>
              <a class="btn btn-sm btn-primary" href={`${base}práctico`}>Ir al práctico</a>
            </div>
          </div>
        </article>
        <article class="official-topic">
          <div class="official-topic-main">
            <div class="official-topic-number">3º</div>
            <div class="official-topic-body">
              <div class="official-topic-meta">
                <span class="badge text-bg-secondary">Indices</span>
                <span class="badge text-bg-dark">Desarrollo</span>
              </div>
              <h3>Tercer ejercicio</h3>
              <p>Esquemas e indices de los temas para memorizar estructura y orden de exposición.</p>
              <a class="btn btn-sm btn-primary" href={`${base}desarrollo`}>Ir a desarrollo</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    {officialGroups.map((group) => (
      <section class="official-group" id={group.id}>
        <div class="official-group-heading">
          <div>
            <h2>{group.titulo}<a class="anchor-link" aria-label="Enlace a esta sección" href={`#${group.id}`}></a></h2>
            <p>{group.descripción}</p>
          </div>
          <span class="badge text-bg-secondary">{group.topics.length} temas</span>
        </div>

        <div class="official-topic-list">
          {group.topics.map((topic) => (
            <article class="official-topic">
              {(() => {
                const slug = officialSlug(topic.grupo, topic.numero);
                const hasOfficialContent = officialContentIds.has(slug);
                return (
              <div class="official-topic-main">
                <div class="official-topic-number">{topic.grupo}.{topic.numero}</div>
                <div class="official-topic-body">
                  <div class="official-topic-meta">
                    <span class={hasOfficialContent ? 'badge text-bg-success' : 'badge text-bg-danger'}>{hasOfficialContent ? 'Tema oficial' : 'Pendiente'}</span>
                    <span class={topic.prioridad === 'crítica' ? 'badge text-bg-primary' : 'badge text-bg-dark'}>{priorityLabel[topic.prioridad]}</span>
                  </div>
                  <h3>{topic.titulo}</h3>
                  {hasOfficialContent ? (
                    <a class="btn btn-sm btn-primary" href={`${base}programa/${slug}`}>Abrir tema</a>
                  ) : (
                    <p class="topic-missing mb-0">Pendiente de crear contenido específico.</p>
                  )}
                </div>
              </div>
                );
              })()}
            </article>
          ))}
        </div>
      </section>
    ))}
  </section>
</Layout>
