---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { officialGroups, syllabusStats } from '../data/burgosSyllabus';

const currentTopics = (await getCollection('temas')).sort((a, b) => a.data.tema - b.data.tema);
const officialContent = await getCollection('programa');
const officialContentIds = new Set(officialContent.map((tema) => tema.id.replace(/\.md$/, '')));
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const statusTone = {
  pendiente: 'danger',
  'base parcial': 'warning',
  'base aprovechable': 'success',
};
const priorityLabel = {
  normal: 'Test y desarrollo',
  alta: 'Alta prioridad',
  critica: 'Practico + desarrollo',
};
const officialSlug = (grupo: string, numero: number) => `grupo-${grupo.toLowerCase()}-tema-${String(numero).padStart(2, '0')}`;
---

<Layout title="Administrativo Burgos 2026">
  <div class="bd-intro ps-lg-2">
    <h1 class="bd-title">Administrativo Burgos</h1>
    <p class="bd-subtitle mb-0">Programa oficial por grupos, con el mapeo inicial del temario anterior para adaptar sin perder material.</p>
  </div>
  <section class="bd-content ps-lg-2">
    <div class="syllabus-summary" aria-label="Resumen del programa">
      <div>
        <strong>{syllabusStats.groups}</strong>
        <span>grupos oficiales</span>
      </div>
      <div>
        <strong>{syllabusStats.topics}</strong>
        <span>temas Burgos</span>
      </div>
      <div>
        <strong>{currentTopics.length}</strong>
        <span>temas antiguos conservados</span>
      </div>
      <div>
        <strong>{syllabusStats.pending}</strong>
        <span>temas sin base clara</span>
      </div>
    </div>

    <div class="bd-callout">
      <strong>Regla de trabajo:</strong> los 48 temas actuales siguen disponibles como base. En esta pantalla mandan los 42 temas oficiales del PDF; cada tema muestra que material antiguo se puede reutilizar o si hay que crearlo desde cero.
    </div>

    {officialGroups.map((group) => (
      <section class="official-group" id={group.id}>
        <div class="official-group-heading">
          <div>
            <h2>{group.titulo}<a class="anchor-link" aria-label="Enlace a esta seccion" href={`#${group.id}`}></a></h2>
            <p>{group.descripcion}</p>
          </div>
          <span class="badge text-bg-secondary">{group.topics.length} temas</span>
        </div>

        <div class="official-topic-list">
          {group.topics.map((topic) => (
            <article class="official-topic">
              {(() => {
                const slug = officialSlug(topic.grupo, topic.numero);
                const hasOfficialContent = officialContentIds.has(slug);
                return (
              <div class="official-topic-main">
                <div class="official-topic-number">{topic.grupo}.{topic.numero}</div>
                <div class="official-topic-body">
                  <div class="official-topic-meta">
                    <span class={`badge text-bg-${statusTone[topic.estado]}`}>{topic.estado}</span>
                    <span class={topic.prioridad === 'critica' ? 'badge text-bg-primary' : 'badge text-bg-dark'}>{priorityLabel[topic.prioridad]}</span>
                  </div>
                  <h3>{topic.titulo}</h3>
                  {hasOfficialContent && (
                    <a class="btn btn-sm btn-primary mb-3" href={`${base}programa/${slug}`}>Abrir tema oficial</a>
                  )}
                  {topic.matches.length > 0 ? (
                    <div class="topic-matches">
                      <span>Material actual relacionado:</span>
                      <div class="topic-match-list">
                        {topic.matches.map((match) => (
                          <a href={`${base}temas/${match.slug}`} class="topic-match">
                            <strong>Tema {match.tema}</strong>
                            <span>{match.titulo}</span>
                            <small>{match.calidad}{match.nota ? ` · ${match.nota}` : ''}</small>
                          </a>
                        ))}
                      </div>
                    </div>
                  ) : (
                    <p class="topic-missing mb-0">Pendiente de crear contenido especifico para Burgos.</p>
                  )}
                </div>
              </div>
                );
              })()}
            </article>
          ))}
        </div>
      </section>
    ))}
  </section>
</Layout>
